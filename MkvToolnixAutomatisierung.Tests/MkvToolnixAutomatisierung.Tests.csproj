<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector" Version="6.0.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MkvToolnixAutomatisierung.csproj" />
  </ItemGroup>

  <!-- Gezielte Testhost-Härtung für die lokale Workspace-Ausführung:
       Der Microsoft.NET.Test.Sdk-Host verweist in seiner deps.json auf die CodeCoverage-Shim-DLL,
       kopiert diese in dieser Umgebung aber nicht verlässlich in den Testoutput. Die Version wird
       absichtlich per Wildcard aus dem NuGet-Cache aufgelöst, damit Paketupdates kein zweites
       hart codiertes Versionsfeld im Projekt hinterlassen. -->
  <Target Name="CopyCodeCoverageShim" AfterTargets="Build">
    <ItemGroup>
      <CodeCoverageShim Include="$(NuGetPackageRoot)microsoft.codecoverage\*\lib\netcoreapp3.1\Microsoft.VisualStudio.CodeCoverage.Shim.dll" />
    </ItemGroup>

    <Copy
      SourceFiles="@(CodeCoverageShim)"
      DestinationFolder="$(OutDir)"
      SkipUnchangedFiles="true"
      Condition="'@(CodeCoverageShim)' != ''" />
  </Target>
</Project>
