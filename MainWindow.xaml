<Window x:Class="MkvToolnixAutomatisierung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MkvToolnixAutomatisierung.Views"
        xmlns:moduleVm="clr-namespace:MkvToolnixAutomatisierung.ViewModels.Modules"
        Title="MKVToolNix-Automatisierung Portable"
        Icon="/Assets/AppIcon.ico"
        Width="1320"
        Height="900"
        MinWidth="1100"
        MinHeight="760"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Verknüpft Modul-ViewModels mit ihren Ansichten, damit die rechte Seite rein datengetrieben umschaltet. -->
        <DataTemplate DataType="{x:Type moduleVm:SingleEpisodeMuxViewModel}">
            <views:SingleEpisodeMuxView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type moduleVm:BatchMuxViewModel}">
            <views:BatchMuxView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type moduleVm:DownloadSortViewModel}">
            <views:DownloadSortView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type moduleVm:EmbySyncViewModel}">
            <views:EmbySyncView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Linke Modulleiste plus globale Status-/Konfigurationsaktionen. -->
        <Border Grid.Column="0"
                Padding="12"
                Background="#F5F5F5"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,10"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Text="Module" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Modules}"
                         SelectedItem="{Binding SelectedModule, Mode=TwoWay}"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ToolTip="Modul auswählen"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    MinHeight="62"
                                    Padding="10"
                                    Background="White"
                                    BorderBrush="#D9D9D9"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding Title}"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding Description}"
                                               Foreground="#555555"
                                               Text="{Binding Description}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Button Padding="10,8"
                            Command="{Binding OpenSettingsCommand}"
                            Content="Einstellungen" />

                    <Border Margin="0,8,0,0"
                            Padding="10,8"
                            Background="#F8FAFC"
                            BorderBrush="#D5DEE8"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Margin="0,0,0,6"
                                       Text="Systemstatus" />
                            <TextBlock Text="{Binding ArchiveStatusText}"
                                       ToolTip="{Binding ArchiveStatusTooltip}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding MkvToolNixStatusText}"
                                       ToolTip="{Binding MkvToolNixStatusTooltip}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding MediaProbeStatusText}"
                                       ToolTip="{Binding MediaProbeStatusTooltip}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding PortableDataStatusText}"
                                       ToolTip="{Binding PortableDataStatusTooltip}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,8,0,0"
                            Padding="10,8"
                            Background="#FFF7E8"
                            BorderBrush="#D8B46A"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasArchiveNotice}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="12"
                                   Foreground="#5B4720"
                                   TextWrapping="Wrap"
                                   Text="{Binding ArchiveNoticeText}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Rechte Hauptfläche hostet jeweils das aktuell gewählte Modul. -->
        <ContentControl Grid.Column="2" Content="{Binding SelectedModule.ContentViewModel}" />
    </Grid>
</Window>
