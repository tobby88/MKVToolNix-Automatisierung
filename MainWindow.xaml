<Window x:Class="MkvToolnixAutomatisierung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MkvToolnixAutomatisierung.Views"
        xmlns:moduleVm="clr-namespace:MkvToolnixAutomatisierung.ViewModels.Modules"
        Title="MKVToolNix-Automatisierung"
        Width="1320"
        Height="900"
        MinWidth="1100"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type moduleVm:SingleEpisodeMuxViewModel}">
            <views:SingleEpisodeMuxView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type moduleVm:BatchMuxViewModel}">
            <views:BatchMuxView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="16"
                Background="#F5F5F5"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,16"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Text="Module" />

                <TextBlock Grid.Row="1"
                           Margin="0,0,0,16"
                           TextWrapping="Wrap"
                           Foreground="#444444"
                           Text="Links Modul waehlen, rechts bearbeiten." />

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Modules}"
                         SelectedItem="{Binding SelectedModule, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="12"
                                    Background="White"
                                    BorderBrush="#D9D9D9"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,4,0,0"
                                               MaxWidth="180"
                                               TextWrapping="Wrap"
                                               Foreground="#555555"
                                               Text="{Binding Description}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <ContentControl Grid.Column="2" Content="{Binding SelectedModule.ContentViewModel}" />
    </Grid>
</Window>
