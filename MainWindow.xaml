<Window x:Class="MkvToolnixAutomatisierung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MkvToolnixAutomatisierung.Views"
        xmlns:moduleVm="clr-namespace:MkvToolnixAutomatisierung.ViewModels.Modules"
        Title="MKVToolNix-Automatisierung Portable"
        Icon="/Assets/AppIcon.ico"
        Width="1320"
        Height="900"
        MinWidth="1100"
        MinHeight="760"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Verknüpft Modul-ViewModels mit ihren Ansichten, damit die rechte Seite rein datengetrieben umschaltet. -->
        <DataTemplate DataType="{x:Type moduleVm:SingleEpisodeMuxViewModel}">
            <views:SingleEpisodeMuxView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type moduleVm:BatchMuxViewModel}">
            <views:BatchMuxView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Linke Modulleiste plus globale Status-/Konfigurationsaktionen. -->
        <Border Grid.Column="0"
                Padding="12"
                Background="#F5F5F5"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,10"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Text="Module" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Modules}"
                         SelectedItem="{Binding SelectedModule, Mode=TwoWay}"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ToolTip="Modul auswählen"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    MinHeight="62"
                                    Padding="10"
                                    Background="White"
                                    BorderBrush="#D9D9D9"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding Title}"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding Description}"
                                               Foreground="#555555"
                                               Text="{Binding Description}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Button Margin="0,0,0,8"
                            Padding="10,8"
                            BorderThickness="1"
                            Command="{Binding SelectFfprobeCommand}"
                            ToolTip="{Binding MediaProbeStatusTooltip}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFF4D6" />
                                <Setter Property="BorderBrush" Value="#D8B46A" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFfprobeAvailable}" Value="True">
                                        <Setter Property="Background" Value="#EEF6E8" />
                                        <Setter Property="BorderBrush" Value="#88B06E" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding MediaProbeStatusText}" />
                    </Button>

                    <Button Padding="10,8"
                            BorderThickness="1"
                            Command="{Binding SelectMkvToolNixCommand}"
                            ToolTip="{Binding MkvToolNixStatusTooltip}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFF4D6" />
                                <Setter Property="BorderBrush" Value="#D8B46A" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMkvToolNixAvailable}" Value="True">
                                        <Setter Property="Background" Value="#EEF6E8" />
                                        <Setter Property="BorderBrush" Value="#88B06E" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding MkvToolNixStatusText}" />
                    </Button>

                    <Button Margin="0,8,0,0"
                            Padding="10,8"
                            BorderThickness="1"
                            Command="{Binding SelectArchiveRootCommand}"
                            ToolTip="{Binding ArchiveStatusTooltip}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFF4D6" />
                                <Setter Property="BorderBrush" Value="#D8B46A" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsArchiveAvailable}" Value="True">
                                        <Setter Property="Background" Value="#EEF6E8" />
                                        <Setter Property="BorderBrush" Value="#88B06E" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding ArchiveStatusText}" />
                    </Button>

                    <Border Margin="0,8,0,0"
                            Padding="10,8"
                            Background="#FFF7E8"
                            BorderBrush="#D8B46A"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasArchiveNotice}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="12"
                                   Foreground="#5B4720"
                                   TextWrapping="Wrap"
                                   Text="{Binding ArchiveNoticeText}" />
                    </Border>

                    <Border Margin="0,10,0,0"
                            Padding="10,8"
                            Background="#F3F6FA"
                            BorderBrush="#C7D1DC"
                            BorderThickness="1"
                            CornerRadius="6"
                            ToolTip="{Binding PortableModeTooltip}">
                        <TextBlock FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Text="{Binding PortableModeText}" />
                    </Border>

                    <Expander Margin="0,8,0,0"
                              IsExpanded="False"
                              ToolTip="Kurze Hinweise zum Erststart und zum aktuell gewählten Modul.">
                        <Expander.Header>
                            <TextBlock FontWeight="SemiBold" Text="Kurzinfo" />
                        </Expander.Header>
                        <Border Margin="0,6,0,0"
                                Padding="8"
                                Background="#FAFBFC"
                                BorderBrush="#D8DEE5"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBlock FontSize="12"
                                       Foreground="#44515D"
                                       TextWrapping="Wrap"
                                       Text="{Binding QuickHelpText}" />
                        </Border>
                    </Expander>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Rechte Hauptfläche hostet jeweils das aktuell gewählte Modul. -->
        <ContentControl Grid.Column="2" Content="{Binding SelectedModule.ContentViewModel}" />
    </Grid>
</Window>
