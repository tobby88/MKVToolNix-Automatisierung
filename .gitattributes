# Normalize text files while keeping Windows-friendly line endings in the working tree.
* text=auto

.editorconfig   text eol=lf
.gitattributes  text eol=lf

*.cs           text eol=crlf
*.csproj       text eol=lf
*.props        text eol=lf
*.targets      text eol=lf
*.sln          text eol=crlf
*.xaml         text eol=crlf
*.xml          text eol=crlf
*.json         text eol=crlf
*.md           text eol=crlf
*.yml          text eol=lf
*.yaml         text eol=lf
*.ps1          text eol=crlf
*.cmd          text eol=crlf
*.bat          text eol=crlf

# Dependabot edits these files through GitHub automation. LF avoids noisy
# full-file diffs when package or workflow versions are bumped.
.config/dotnet-tools.json text eol=lf

*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.zip          binary
*.7z           binary
*.exe          binary
*.dll          binary
*.pdb          binary
