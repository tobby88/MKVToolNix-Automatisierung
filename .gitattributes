# Normalize text files while keeping Windows-friendly line endings in the working tree.
* text=auto

*.cs           text eol=crlf
*.csproj       text eol=crlf
*.props        text eol=crlf
*.targets      text eol=crlf
*.sln          text eol=crlf
*.xaml         text eol=crlf
*.xml          text eol=crlf
*.json         text eol=crlf
*.md           text eol=crlf
*.yml          text eol=crlf
*.yaml         text eol=crlf
*.ps1          text eol=crlf
*.cmd          text eol=crlf
*.bat          text eol=crlf

*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.zip          binary
*.7z           binary
*.exe          binary
*.dll          binary
*.pdb          binary
