# Normalize text files to LF in the index and in the working tree.
# This matches the line endings produced by apply_patch, GitHub web edits and
# Dependabot, so routine edits no longer trigger CRLF conversion warnings.
* text=auto eol=lf

*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.zip          binary
*.7z           binary
*.exe          binary
*.dll          binary
*.pdb          binary
