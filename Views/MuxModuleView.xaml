<UserControl x:Class="MkvToolnixAutomatisierung.Views.MuxModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MkvToolnixAutomatisierung.Views">
    <Grid>
        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="Einzel-Mux">
                <views:SingleEpisodeMuxView DataContext="{Binding SingleMux}" />
            </TabItem>
            <TabItem Header="Batch-Mux">
                <views:BatchMuxView DataContext="{Binding BatchMux}" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
