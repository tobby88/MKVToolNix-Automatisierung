<UserControl x:Class="MkvToolnixAutomatisierung.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#123C69" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0C2A4A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0B2F55" />
                                <Setter Property="BorderBrush" Value="#071F38" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#8DA2B6" />
                                <Setter Property="BorderBrush" Value="#7A8EA1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Border Padding="18"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Text="Download" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#4D5B68"
                               TextWrapping="Wrap"
                               Text="Startet MediathekView als ersten Workflow-Schritt. Die eigentlichen Downloads bleiben dort; danach geht es hier mit Einsortieren und Muxen weiter." />
                </StackPanel>

                <Border Grid.Row="2"
                        Padding="14"
                        Background="#F8FAFC"
                        BorderBrush="#D5DEE8"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,18,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding MediathekViewStatusText}" />
                            <TextBlock Margin="0,5,0,0"
                                       Foreground="#4D5B68"
                                       TextWrapping="Wrap"
                                       Text="{Binding MediathekViewPathText}" />
                        </StackPanel>

                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Width="190"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding StartMediathekViewCommand}"
                                Content="MediathekView starten" />

                        <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Margin="0,14,0,0"
                                    Orientation="Horizontal">
                            <Button Width="150"
                                    Padding="10,6"
                                    Command="{Binding OpenToolSettingsCommand}"
                                    Content="Pfad einstellen" />
                            <Button Width="120"
                                    Margin="10,0,0,0"
                                    Padding="10,6"
                                    Command="{Binding RefreshCommand}"
                                    Content="Neu suchen" />
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Margin="0,14,0,0"
                                   Foreground="#4D5B68"
                                   TextWrapping="Wrap"
                                   Text="{Binding StatusText}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
