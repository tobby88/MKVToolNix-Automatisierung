<UserControl x:Class="MkvToolnixAutomatisierung.Views.DownloadSortView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF1F5FB8" />
            <Setter Property="BorderBrush" Value="#FF174A90" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF174A90" />
                                <Setter Property="BorderBrush" Value="#FF123A72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF123A72" />
                                <Setter Property="BorderBrush" Value="#FF0D2C57" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF5F6B76" />
                                <Setter Property="Background" Value="#FFE5E7EB" />
                                <Setter Property="BorderBrush" Value="#FFD0D7DE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="160" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10" IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,8,12,8"
                       VerticalAlignment="Center"
                       Text="Downloadordner" />
            <TextBox Grid.Column="1"
                     Margin="0,4,12,4"
                     IsReadOnly="True"
                     Text="{Binding SourceDirectory, Mode=OneWay}" />
            <Button Grid.Column="2"
                    Margin="0,2,12,2"
                    Padding="10,6"
                    Command="{Binding SelectSourceDirectoryCommand}"
                    Content="Ordner wählen" />
            <Button Grid.Column="3"
                    Margin="0,2,0,2"
                    Padding="10,6"
                    Command="{Binding ScanCommand}"
                    ToolTip="{Binding ScanTooltip, Mode=OneWay}"
                    Content="Neu scannen" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="10,8"
                Background="#F8F4E8"
                BorderBrush="#D9C28A"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock TextWrapping="Wrap"
                       Text="{Binding SummaryText, Mode=OneWay}" />
        </Border>

        <GroupBox Grid.Row="2" Header="Lose Download-Pakete">
            <DataGrid x:Name="DownloadItemsGrid"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HorizontalScrollBarVisibility="Auto"
                      IsReadOnly="False"
                      IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                      KeyboardNavigation.DirectionalNavigation="Contained"
                      ColumnWidth="*"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      PreviewKeyDown="DownloadItemsGrid_OnPreviewKeyDown"
                      PreviewMouseLeftButtonDown="DownloadItemsGrid_OnPreviewMouseLeftButtonDown"
                      Margin="8"
                      MinHeight="180">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Auswahl"
                                            Width="SizeToHeader"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          IsHitTestVisible="False"
                                          IsChecked="{Binding IsSelected, Mode=OneWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Download"
                                        Binding="{Binding DisplayName}"
                                        Width="2.2*"
                                        MinWidth="150"
                                        IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Zielordner"
                                            Width="1.3*"
                                            MinWidth="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox Margin="0,1"
                                          Padding="4,1"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          ItemsSource="{Binding DataContext.TargetFolderOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          Text="{Binding TargetFolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Zielordner auswählen oder frei eintippen. Der Wert wird vor dem Einsortieren erneut geprüft." />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Status"
                                            Width="Auto"
                                            MinWidth="56"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Margin="2"
                                        Padding="6,2"
                                        CornerRadius="9"
                                        BorderThickness="1"
                                        Background="{Binding StatusBadgeBackground}"
                                        BorderBrush="{Binding StatusBadgeBorderBrush}">
                                    <TextBlock HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="{Binding StatusText}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Hinweis"
                                            Width="2.5*"
                                            MinWidth="280"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="4,2"
                                           Text="{Binding Note}"
                                           TextWrapping="Wrap"
                                           ToolTip="{Binding Note}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="3"
                    Margin="0,10,0,10"
                    Orientation="Horizontal"
                    IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding SelectAllSortableCommand}"
                    Content="Alle Einsortierbaren wählen" />
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding DeselectAllCommand}"
                    Content="Auswahl leeren" />
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding ApplyTargetFolderToMatchingItemsCommand}"
                    ToolTip="Übernimmt den Zielordner des markierten Eintrags für weitere Einträge mit demselben ursprünglich erkannten Zielordner."
                    Content="Zielordner übernehmen" />
            <Button Padding="10,6"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding RunSortCommand}"
                    ToolTip="{Binding RunSortTooltip, Mode=OneWay}"
                    Content="Auswahl einsortieren" />
        </StackPanel>

        <GroupBox Grid.Row="4" Header="Protokoll">
            <TextBox Margin="8"
                     Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled" />
        </GroupBox>

        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding StatusText, Mode=OneWay}" />
            <ProgressBar Grid.Column="1"
                         Height="18"
                         Margin="12,0,0,0"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressValue, Mode=OneWay}">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInteractive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </Grid>
    </Grid>
</UserControl>
