<UserControl x:Class="MkvToolnixAutomatisierung.Views.EmbySyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="EditableIdTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFF9E2" />
            <Setter Property="BorderBrush" Value="#D8B24A" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFF3F4F6" />
                    <Setter Property="BorderBrush" Value="#D0D7DE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RowActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF1F5FB8" />
            <Setter Property="BorderBrush" Value="#FF174A90" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF174A90" />
                                <Setter Property="BorderBrush" Value="#FF123A72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF123A72" />
                                <Setter Property="BorderBrush" Value="#FF0D2C57" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF5F6B76" />
                                <Setter Property="Background" Value="#FFE5E7EB" />
                                <Setter Property="BorderBrush" Value="#FFD0D7DE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFF3F4F6" />
            <Setter Property="BorderBrush" Value="#FFD0D7DE" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Ready">
                    <Setter Property="Background" Value="#FFE9F8EE" />
                    <Setter Property="BorderBrush" Value="#FF63A46C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Done">
                    <Setter Property="Background" Value="#FFE9F2FF" />
                    <Setter Property="BorderBrush" Value="#FF4C84D3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Background" Value="#FFFFF4D6" />
                    <Setter Property="BorderBrush" Value="#FFD6A62A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                    <Setter Property="Background" Value="#FFFDEBEC" />
                    <Setter Property="BorderBrush" Value="#FFC94F57" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF5F6B76" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Ready">
                    <Setter Property="Foreground" Value="#FF1E6E35" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Done">
                    <Setter Property="Foreground" Value="#FF1F5FB8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Foreground" Value="#FF8A5A00" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                    <Setter Property="Foreground" Value="#FFAA2E34" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,10"
              IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Width="165"
                    Height="34"
                    Margin="0,2,12,2"
                    Padding="10,6"
                    VerticalAlignment="Top"
                    Command="{Binding SelectReportCommand}"
                    Content="Reports wählen" />
            <Border Grid.Row="0"
                     Grid.Column="1"
                    Margin="0,2,0,2"
                    Padding="10,8"
                    MinHeight="34"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFD8DEE6"
                    BorderThickness="1"
                    CornerRadius="4"
                    ToolTip="{Binding ReportSelectionTooltip, Mode=OneWay}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding ReportSelectionSummaryText, Mode=OneWay}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="#FF4B5563"
                               Text="{Binding ReportSelectionDetailText, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Width="165"
                    Height="34"
                    Margin="0,2,12,2"
                    Padding="10,6"
                    VerticalAlignment="Top"
                    Command="{Binding RunScanCommand}"
                    Content="Emby scannen"
                    ToolTip="{Binding RunScanTooltip, Mode=OneWay}" />
            <Border Grid.Row="1"
                  Grid.Column="1"
                    Margin="0,2,0,2"
                    Padding="10,8"
                    MinHeight="34"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFD8DEE6"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock Foreground="#FF4B5563"
                           Text="Optionaler Zwischenschritt: lässt Emby neue Dateien erkennen und prüft die betroffenen Zeilen danach automatisch erneut."
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <GroupBox Grid.Row="1" Header="Neue MKV-Dateien">
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HorizontalScrollBarVisibility="Auto"
                      IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                      IsReadOnly="False"
                      ColumnWidth="*"
                      PreviewKeyDown="EmbyItemsGrid_OnPreviewKeyDown"
                      PreviewMouseLeftButtonDown="EmbyItemsGrid_OnPreviewMouseLeftButtonDown"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      Margin="8"
                      MinHeight="220">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Auswahl"
                                            Width="SizeToHeader"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          IsHitTestVisible="False"
                                          IsChecked="{Binding IsSelected, Mode=OneWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="MKV"
                                        Binding="{Binding MediaFileName}"
                                        Width="2.4*"
                                        MinWidth="240"
                                        IsReadOnly="True" />
                    <DataGridTemplateColumn Header="TVDB-ID"
                                            Width="150"
                                            MinWidth="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource EditableIdTextBoxStyle}"
                                             IsEnabled="{Binding CanEditProviderIds}"
                                             ToolTip="{Binding ProviderIdEditTooltip}"
                                             Text="{Binding TvdbId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
                                    <Button Grid.Column="1"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource RowActionButtonStyle}"
                                            Click="TvdbLookupButton_OnClick"
                                            Content="TVDB"
                                            IsEnabled="{Binding CanReviewTvdb}"
                                            ToolTip="{Binding TvdbLookupTooltip}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="IMDB-ID"
                                            Width="150"
                                            MinWidth="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource EditableIdTextBoxStyle}"
                                             IsEnabled="{Binding CanEditProviderIds}"
                                             ToolTip="{Binding ProviderIdEditTooltip}"
                                             Text="{Binding ImdbId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
                                    <Button Grid.Column="1"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource RowActionButtonStyle}"
                                            Click="ImdbLookupButton_OnClick"
                                            Content="IMDb"
                                            IsEnabled="{Binding CanReviewImdb}"
                                            ToolTip="{Binding ImdbLookupTooltip}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Status"
                                            Width="Auto"
                                            MinWidth="120"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Margin="4,2"
                                        Style="{StaticResource StatusBadgeBorderStyle}"
                                        ToolTip="{Binding StatusTooltip}">
                                    <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                                               Text="{Binding StatusText}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Hinweis"
                                            Width="2.5*"
                                            MinWidth="260"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="4,2"
                                           Text="{Binding Note}"
                                           TextWrapping="Wrap"
                                           ToolTip="{Binding Note}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Expander Grid.Row="2"
                  Margin="0,10,0,0"
                  Header="Protokoll"
                  IsExpanded="False"
                  Expanded="LogExpander_OnExpanded">
            <Border Margin="0,6,0,0"
                    BorderBrush="#D8DEE6"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBox x:Name="LogTextBox"
                         Margin="8"
                         MinHeight="150"
                         Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         TextChanged="LogTextBox_OnTextChanged" />
            </Border>
        </Expander>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding SummaryText, Mode=OneWay}" />
            <Button Grid.Column="1"
                    Margin="12,0,8,0"
                    Padding="10,6"
                    Command="{Binding SelectAllCommand}"
                    IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                    Content="Alle wählen" />
            <Button Grid.Column="2"
                    Margin="0,0,12,0"
                    Padding="10,6"
                    Command="{Binding DeselectAllCommand}"
                    IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                    Content="Auswahl leeren" />
            <Button Grid.Column="3"
                    Margin="20,0,12,0"
                    MinWidth="210"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding RunSyncCommand}"
                    ToolTip="{Binding RunSyncTooltip, Mode=OneWay}"
                    Content="Änderungen in Emby schreiben" />
            <ProgressBar Grid.Column="4"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressValue, Mode=OneWay}"
                         ToolTip="{Binding StatusText, Mode=OneWay}">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInteractive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </Grid>
    </Grid>
</UserControl>
