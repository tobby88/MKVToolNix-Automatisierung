<UserControl x:Class="MkvToolnixAutomatisierung.Views.EmbySyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="EditableIdTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFF9E2" />
            <Setter Property="BorderBrush" Value="#D8B24A" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFF3F4F6" />
                    <Setter Property="BorderBrush" Value="#D0D7DE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RowActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0"
                  Header="Emby-Verbindung"
                  IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,8,12,8"
                           VerticalAlignment="Center"
                           Text="Server" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="0,4,12,4"
                         Text="{Binding ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Basisadresse des Emby-Servers, z. B. http://t-emby:8096" />
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Margin="0,2,12,2"
                        Padding="10,6"
                        Command="{Binding SaveSettingsCommand}"
                        Content="Speichern" />
                <Button Grid.Row="0"
                        Grid.Column="3"
                        Margin="0,2,0,2"
                        Padding="10,6"
                        Command="{Binding TestConnectionCommand}"
                        Content="Verbindung testen" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,8,12,8"
                           VerticalAlignment="Center"
                           Text="API-Key" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="3"
                         Margin="0,4,0,4"
                         Text="{Binding ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="API-Key aus dem Emby-Dashboard." />
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1"
              Margin="0,0,0,10"
              IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,8,12,8"
                       VerticalAlignment="Center"
                       Text="Metadatenreports" />
            <TextBox Grid.Row="0"
                     Grid.Column="1"
                     Margin="0,4,12,4"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     MinHeight="34"
                     MaxHeight="92"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding ReportPath, Mode=OneWay}" />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Margin="0,2,0,2"
                    Padding="10,6"
                    MinWidth="150"
                    Command="{Binding SelectReportCommand}"
                    Content="1. Reports wählen" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,8,12,8"
                       VerticalAlignment="Center"
                       Text="Workflow" />
            <Grid Grid.Row="1"
                  Grid.Column="1"
                  Grid.ColumnSpan="2"
                  Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Margin="0,0,12,8"
                        Padding="10,6"
                        Command="{Binding RunScanCommand}"
                        Content="2. Emby scannen"
                        ToolTip="{Binding RunScanTooltip, Mode=OneWay}" />
                <Button Grid.Column="1"
                        Margin="0,0,12,8"
                        Padding="10,6"
                        Command="{Binding AnalyzeItemsCommand}"
                        ToolTip="{Binding AnalyzeItemsTooltip, Mode=OneWay}"
                        Content="3. NFO/Emby prüfen" />
                <Button Grid.Column="2"
                        Margin="0,0,0,8"
                        Padding="10,6"
                        Command="{Binding RunSyncCommand}"
                        ToolTip="{Binding RunSyncTooltip, Mode=OneWay}"
                        Content="5. NFO-Sync" />
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,0,0,10"
                Padding="10,8"
                Background="#F4F7FB"
                BorderBrush="#BCD0E5"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock TextWrapping="Wrap"
                       Text="{Binding WorkflowInfoText, Mode=OneWay}" />
        </Border>

        <GroupBox Grid.Row="3" Header="Neue MKV-Dateien">
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HorizontalScrollBarVisibility="Auto"
                      IsReadOnly="False"
                      ColumnWidth="*"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      Margin="8"
                      MinHeight="220">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Auswahl"
                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="SizeToHeader" />
                    <DataGridTextColumn Header="MKV"
                                        Binding="{Binding MediaFileName}"
                                        Width="1.6*"
                                        MinWidth="180"
                                        IsReadOnly="True" />
                    <DataGridTemplateColumn Header="TVDB-ID"
                                            Width="1.1*"
                                            MinWidth="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource EditableIdTextBoxStyle}"
                                             IsEnabled="{Binding CanEditProviderIds}"
                                             ToolTip="{Binding ProviderIdEditTooltip}"
                                             Text="{Binding TvdbId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
                                    <Button Grid.Column="1"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource RowActionButtonStyle}"
                                            Click="TvdbLookupButton_OnClick"
                                            Content="TVDB"
                                            IsEnabled="{Binding CanReviewTvdb}"
                                            ToolTip="{Binding TvdbLookupTooltip}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="IMDB-ID"
                                            Width="0.9*"
                                            MinWidth="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Margin="4,2"
                                         Style="{StaticResource EditableIdTextBoxStyle}"
                                         IsEnabled="{Binding CanEditProviderIds}"
                                         ToolTip="{Binding ProviderIdEditTooltip}"
                                         Text="{Binding ImdbId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Emby"
                                        Binding="{Binding EmbyItemId}"
                                        Width="0.7*"
                                        MinWidth="90"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding StatusText}"
                                        Width="Auto"
                                        MinWidth="100"
                                        IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Hinweis"
                                            Width="2.2*"
                                            MinWidth="260"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="4,2"
                                           Text="{Binding Note}"
                                           TextWrapping="Wrap"
                                           ToolTip="{Binding Note}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Expander Grid.Row="4"
                  Margin="0,10,0,0"
                  Header="Protokoll"
                  IsExpanded="False"
                  Expanded="LogExpander_OnExpanded">
            <Border Margin="0,6,0,0"
                    BorderBrush="#D8DEE6"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBox x:Name="LogTextBox"
                         Margin="8"
                         MinHeight="150"
                         Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         TextChanged="LogTextBox_OnTextChanged" />
            </Border>
        </Expander>

        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding SummaryText, Mode=OneWay}" />
            <Button Grid.Column="1"
                    Margin="12,0,8,0"
                    Padding="10,6"
                    Command="{Binding SelectAllCommand}"
                    IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                    Content="Alle wählen" />
            <Button Grid.Column="2"
                    Margin="0,0,12,0"
                    Padding="10,6"
                    Command="{Binding DeselectAllCommand}"
                    IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                    Content="Auswahl leeren" />
            <ProgressBar Grid.Column="3"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressValue, Mode=OneWay}"
                         ToolTip="{Binding StatusText, Mode=OneWay}">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInteractive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </Grid>
    </Grid>
</UserControl>
