<UserControl x:Class="MkvToolnixAutomatisierung.Views.ArchiveMaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="DisplaySurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7F7F7" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style x:Key="CompactDisplaySurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource DisplaySurfaceBorderStyle}">
            <Setter Property="Padding" Value="6,3" />
        </Style>

        <Style x:Key="DisplaySurfaceTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="DisplaySurfacePathTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF1F5FB8" />
            <Setter Property="BorderBrush" Value="#FF174A90" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF174A90" />
                                <Setter Property="BorderBrush" Value="#FF123A72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF123A72" />
                                <Setter Property="BorderBrush" Value="#FF0D2C57" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF5F6B76" />
                                <Setter Property="Background" Value="#FFE5E7EB" />
                                <Setter Property="BorderBrush" Value="#FFD0D7DE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFF3F4F6" />
            <Setter Property="BorderBrush" Value="#FFD0D7DE" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Ready">
                    <Setter Property="Background" Value="#FFE9F8EE" />
                    <Setter Property="BorderBrush" Value="#FF63A46C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Done">
                    <Setter Property="Background" Value="#FFE9F2FF" />
                    <Setter Property="BorderBrush" Value="#FF4C84D3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Background" Value="#FFFFF4D6" />
                    <Setter Property="BorderBrush" Value="#FFD6A62A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                    <Setter Property="Background" Value="#FFFDEBEC" />
                    <Setter Property="BorderBrush" Value="#FFC94F57" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF5F6B76" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Ready">
                    <Setter Property="Foreground" Value="#FF1E6E35" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Done">
                    <Setter Property="Foreground" Value="#FF1F5FB8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Foreground" Value="#FF8A5A00" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                    <Setter Property="Foreground" Value="#FFAA2E34" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="ArchiveItemsRow" Height="1.35*" MinHeight="110" />
            <RowDefinition Height="6" />
            <RowDefinition x:Name="PlannedMaintenanceRow" Height="0.95*" MinHeight="150" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="ManualCorrectionRow" Height="Auto" MinHeight="0" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,10"
              IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,8,12,8"
                       VerticalAlignment="Center"
                       Text="Archivordner" />
            <TextBox Grid.Column="1"
                     Margin="0,4,12,4"
                     IsReadOnly="True"
                     Text="{Binding RootDirectory, Mode=OneWay}" />
            <Button Grid.Column="2"
                    Margin="0,2,12,2"
                    Padding="10,6"
                    Command="{Binding SelectRootDirectoryCommand}"
                    Content="Ordner wählen" />
            <Button Grid.Column="3"
                    Margin="0,2,0,2"
                    Padding="10,6"
                    Command="{Binding ScanCommand}"
                    Content="Scannen" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="10,8"
                Background="#FFF8FAFC"
                BorderBrush="#FFD8DEE6"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock TextWrapping="Wrap"
                       Text="{Binding SummaryText, Mode=OneWay}" />
        </Border>

        <GroupBox Grid.Row="2" Header="Archivdateien">
            <GroupBox.Style>
                <Style TargetType="GroupBox">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded, ElementName=ManualCorrectionExpander}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </GroupBox.Style>
            <DataGrid x:Name="ArchiveItemsGrid"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HorizontalScrollBarVisibility="Auto"
                      IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                      IsReadOnly="False"
                      ColumnWidth="*"
                      VerticalScrollBarVisibility="Auto"
                      KeyboardNavigation.DirectionalNavigation="Contained"
                      PreviewKeyDown="ArchiveItemsGrid_OnPreviewKeyDown"
                      PreviewMouseLeftButtonDown="ArchiveItemsGrid_OnPreviewMouseLeftButtonDown"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      Margin="8"
                      MinHeight="90">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Auswahl"
                                            Width="SizeToHeader"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          IsHitTestVisible="False"
                                          IsChecked="{Binding IsSelected, Mode=OneWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="MKV"
                                        Binding="{Binding FileName}"
                                        Width="2.2*"
                                        MinWidth="260"
                                        IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Status"
                                            Width="Auto"
                                            MinWidth="100"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Margin="2"
                                        Style="{StaticResource StatusBadgeBorderStyle}">
                                    <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                                               Text="{Binding StatusText}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Änderungen / Hinweise"
                                        Binding="{Binding ChangeSummary}"
                                        Width="3*"
                                        MinWidth="360"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Ordner"
                                        Binding="{Binding DirectoryPath}"
                                        Width="1.6*"
                                        MinWidth="180"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border Grid.Row="2"
                Margin="0,2,0,2"
                Padding="10,8"
                Background="#FFF8FAFC"
                BorderBrush="#FFD8DEE6"
                BorderThickness="1"
                CornerRadius="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded, ElementName=ManualCorrectionExpander}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Margin="0,4,10,4"
                           VerticalAlignment="Center"
                           Text="Archivdatei" />
                <ComboBox Grid.Column="1"
                          Margin="0,0,12,0"
                          DisplayMemberPath="FileName"
                          ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}" />
                <Border Grid.Column="2"
                        Margin="0,0,12,0"
                        DataContext="{Binding SelectedItem}"
                        Style="{StaticResource StatusBadgeBorderStyle}">
                    <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                               Text="{Binding StatusText, TargetNullValue=-}" />
                </Border>
                <TextBlock Grid.Column="3"
                           VerticalAlignment="Center"
                           Text="{Binding SelectedItem.ChangeSummary, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <GridSplitter Grid.Row="3"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#FFD6D6D6"
                      ShowsPreview="True"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext" />

        <GroupBox Grid.Row="4"
                  Margin="0,10,0,0"
                  Header="Geplante Archivpflege der ausgewählten Datei">
            <Grid Margin="8">
                <Border Padding="18"
                        Background="#F8F8F8"
                        BorderBrush="#D5D5D5"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Text="Noch keine Archivdatei ausgewählt" />
                </Border>

                <Border Padding="8,6"
                        DataContext="{Binding SelectedItem}"
                        Background="#FFF8FAFC"
                        BorderBrush="#FFD8DEE6"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded, ElementName=ManualCorrectionExpander}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.SelectedItem, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding FileName, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Margin="16,0,0,0"
                                   Foreground="#FF5F6B76"
                                   Text="{Binding DetailSummaryText, Mode=OneWay}" />
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsExpanded, ElementName=ManualCorrectionExpander}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel DataContext="{Binding SelectedItem}">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="{Binding FileName, Mode=OneWay}" />
                        <TextBlock Margin="0,2,0,8"
                                   Foreground="#FF5F6B76"
                                   Text="{Binding DetailSummaryText, Mode=OneWay}" />

                        <Border Margin="0,0,0,8"
                                Style="{StaticResource DisplaySurfaceBorderStyle}">
                            <TextBox Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                     Text="{Binding DetailFilePath, Mode=OneWay}" />
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="#FFE9F8EE"
                                BorderBrush="#FF63A46C"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNoDetailFindings, Mode=OneWay}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF1E6E35"
                                       Text="Keine Änderung nötig." />
                        </Border>

                        <GroupBox Margin="0,0,0,8"
                                  Header="Direkt schreibbare Änderungen">
                            <GroupBox.Style>
                                <Style TargetType="GroupBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasWritableDetailChanges, Mode=OneWay}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </GroupBox.Style>
                            <ItemsControl Margin="8"
                                          ItemsSource="{Binding WritableChangeNotes, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,4"
                                                   Style="{StaticResource DisplaySurfaceTextStyle}"
                                                   Text="{Binding StringFormat=- {0}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <GroupBox Margin="0,0,0,8"
                                  Header="Nicht automatisch korrigierbar">
                            <GroupBox.Style>
                                <Style TargetType="GroupBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasIssues, Mode=OneWay}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </GroupBox.Style>
                            <ItemsControl Margin="8"
                                          ItemsSource="{Binding IssueMessages, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,4"
                                                   Style="{StaticResource DisplaySurfaceTextStyle}"
                                                   Text="{Binding StringFormat=- {0}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <GroupBox Header="Begleitdateien werden mit umbenannt">
                            <GroupBox.Style>
                                <Style TargetType="GroupBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSidecarRenameNotes, Mode=OneWay}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </GroupBox.Style>
                            <ItemsControl Margin="8"
                                          ItemsSource="{Binding SidecarRenameNotes, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,4"
                                                   Style="{StaticResource DisplaySurfaceTextStyle}"
                                                   Text="{Binding StringFormat=- {0}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </GroupBox>

        <GridSplitter x:Name="ManualCorrectionSplitter"
                      Grid.Row="5"
                      Height="6"
                      Margin="0,10,0,0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#FFD6D6D6"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"
                      ShowsPreview="True"
                      Visibility="Collapsed" />

        <Expander x:Name="ManualCorrectionExpander"
                  Grid.Row="6"
                  Margin="0,10,0,0"
                  Header="{Binding SelectedItem.ManualCorrectionHeaderText, Mode=OneWay, TargetNullValue=Manuelle Korrektur, FallbackValue=Manuelle Korrektur}"
                  IsExpanded="False"
                  Collapsed="ManualCorrectionExpander_OnCollapsed"
                  Expanded="ManualCorrectionExpander_OnExpanded">
            <Border Padding="8"
                    DataContext="{Binding SelectedItem}"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFD8DEE6"
                    BorderThickness="1">
                <Grid IsEnabled="{Binding CanEditManualCorrections, Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="120" />
                    </Grid.RowDefinitions>

                    <Border Margin="0,0,0,8"
                            Padding="8"
                            Background="White"
                            BorderBrush="#FFD8DEE6"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,4,12,4"
                                       VerticalAlignment="Center"
                                       Text="Ziel-Dateiname" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,2,0,2"
                                     Text="{Binding TargetFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,4,12,4"
                                       VerticalAlignment="Center"
                                       Text="MKV-Titel" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,2,0,2"
                                     Text="{Binding TargetContainerTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,0,0,8"
                            Padding="8"
                            Background="White"
                            BorderBrush="#FFD8DEE6"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="7"
                                       Margin="0,0,0,6"
                                       Foreground="#FF5F6B76"
                                       Text="{Binding ProviderIdSummaryText, Mode=OneWay}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,4,12,4"
                                       VerticalAlignment="Center"
                                       Text="Provider-IDs" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,2,6,2"
                                     IsEnabled="{Binding HasProviderIdSync, Mode=OneWay}"
                                     Text="{Binding TargetTvdbId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,2,16,2"
                                    Padding="8,4"
                                    Command="{Binding DataContext.ReviewSelectedTvdbCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="TVDB"
                                    ToolTip="TVDB-Zuordnung für die aktuell ausgewählte Archivdatei prüfen und bei Übernahme Datei/Titel/TVDB-ID vorbereiten." />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="3"
                                       Margin="0,4,8,4"
                                       VerticalAlignment="Center"
                                       Text="IMDb" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="4"
                                     Margin="0,2,6,2"
                                     IsEnabled="{Binding HasProviderIdSync, Mode=OneWay}"
                                     Text="{Binding TargetImdbId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="1"
                                    Grid.Column="5"
                                    Margin="0,2,16,2"
                                    Padding="8,4"
                                    Command="{Binding DataContext.ReviewSelectedImdbCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="IMDb"
                                    ToolTip="IMDb-Zuordnung für die aktuell ausgewählte Archivdatei prüfen und als NFO-Änderung vorbereiten." />
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2"
                               Margin="0,0,0,8"
                               Foreground="#FFAA2E34"
                               TextWrapping="Wrap"
                               Text="{Binding ManualValidationMessage, Mode=OneWay}" />

                    <Border Grid.Row="3"
                            Padding="8"
                            Background="White"
                            BorderBrush="#FFD8DEE6"
                            BorderThickness="1"
                            CornerRadius="4">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top"
                                       Margin="0,0,0,8">
                                <CheckBox DockPanel.Dock="Right"
                                          Margin="12,0,0,0"
                                          VerticalAlignment="Center"
                                          Content="Alle Track-Werte anzeigen"
                                          IsChecked="{Binding ShowAllHeaderCorrections, Mode=TwoWay}" />
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Track-Header" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="#FF5F6B76"
                                               TextWrapping="Wrap"
                                               Text="{Binding HeaderCorrectionModeText, Mode=OneWay}" />
                                </StackPanel>
                            </DockPanel>

                            <TextBlock Margin="0,0,0,4"
                                       Foreground="#FF5F6B76"
                                       Text="Keine Track-Werte sichtbar. Aktiviere bei Bedarf „Alle Track-Werte anzeigen“."
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding VisibleHeaderCorrectionGroupCount, Mode=OneWay}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid DockPanel.Dock="Top"
                                  Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Foreground="#FF5F6B76"
                                           FontWeight="SemiBold"
                                           Text="Spur" />
                                <TextBlock Grid.Column="1"
                                           Foreground="#FF5F6B76"
                                           FontWeight="SemiBold"
                                           Text="Wert" />
                                <TextBlock Grid.Column="2"
                                           Foreground="#FF5F6B76"
                                           FontWeight="SemiBold"
                                           Text="Ist" />
                                <TextBlock Grid.Column="3"
                                           Foreground="#FF5F6B76"
                                           FontWeight="SemiBold"
                                           Text="Soll" />
                            </Grid>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding VisibleHeaderCorrectionGroups, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,6"
                                                    Padding="0"
                                                    Background="#FFF8FAFC"
                                                    BorderBrush="#FFD8DEE6"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Padding="8,6"
                                                            Background="#FFEFF6FF"
                                                            BorderBrush="#FFD8DEE6"
                                                            BorderThickness="0,0,1,0">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{Binding DisplayLabel, Mode=OneWay}"
                                                                   TextWrapping="Wrap" />
                                                    </Border>

                                                    <ItemsControl Grid.Column="1"
                                                                  Margin="6,4"
                                                                  ItemsSource="{Binding Values, Mode=OneWay}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,3">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="104" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Margin="0,4,8,4"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding DisplayName, Mode=OneWay}" />
                                                                    <Border Grid.Column="1"
                                                                            Margin="0,0,8,0"
                                                                            Style="{StaticResource CompactDisplaySurfaceBorderStyle}">
                                                                        <TextBlock Text="{Binding CurrentDisplayValue, Mode=OneWay}"
                                                                                   TextWrapping="Wrap" />
                                                                    </Border>
                                                                    <Grid Grid.Column="2">
                                                                        <TextBox Text="{Binding TargetValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Visibility="{Binding IsTextValue, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                        <ComboBox ItemsSource="{Binding AvailableFlagValues}"
                                                                                  SelectedItem="{Binding TargetValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  Visibility="{Binding IsFlag, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    </Grid>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Expander>

        <StackPanel Grid.Row="7"
                    Margin="0,10,0,10"
                    Orientation="Horizontal"
                    IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding SelectAllWritableCommand}"
                    Content="Alle Änderbaren wählen" />
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding DeselectAllCommand}"
                    Content="Auswahl leeren" />
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding OpenSelectedFileCommand}"
                    Content="Datei öffnen" />
            <Button Padding="10,6"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding ApplySelectedCommand}"
                    Content="Ausgewählte Änderungen anwenden" />
        </StackPanel>

        <Expander Grid.Row="8"
                  Header="Protokoll"
                  IsExpanded="False"
                  Expanded="LogExpander_OnExpanded">
            <TextBox x:Name="LogTextBox"
                     Margin="8"
                     MinHeight="130"
                     MaxHeight="220"
                     Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     TextChanged="LogTextBox_OnTextChanged" />
        </Expander>

        <Grid Grid.Row="9" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding StatusText, Mode=OneWay}" />
            <ProgressBar Grid.Column="1"
                         Height="18"
                         Margin="12,0,0,0"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressValue, Mode=OneWay}">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInteractive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </Grid>
    </Grid>
</UserControl>
