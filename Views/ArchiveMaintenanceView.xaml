<UserControl x:Class="MkvToolnixAutomatisierung.Views.ArchiveMaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF1F5FB8" />
            <Setter Property="BorderBrush" Value="#FF174A90" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF174A90" />
                                <Setter Property="BorderBrush" Value="#FF123A72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF123A72" />
                                <Setter Property="BorderBrush" Value="#FF0D2C57" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF5F6B76" />
                                <Setter Property="Background" Value="#FFE5E7EB" />
                                <Setter Property="BorderBrush" Value="#FFD0D7DE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFF3F4F6" />
            <Setter Property="BorderBrush" Value="#FFD0D7DE" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Ready">
                    <Setter Property="Background" Value="#FFE9F8EE" />
                    <Setter Property="BorderBrush" Value="#FF63A46C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Done">
                    <Setter Property="Background" Value="#FFE9F2FF" />
                    <Setter Property="BorderBrush" Value="#FF4C84D3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Background" Value="#FFFFF4D6" />
                    <Setter Property="BorderBrush" Value="#FFD6A62A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                    <Setter Property="Background" Value="#FFFDEBEC" />
                    <Setter Property="BorderBrush" Value="#FFC94F57" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF5F6B76" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Ready">
                    <Setter Property="Foreground" Value="#FF1E6E35" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Done">
                    <Setter Property="Foreground" Value="#FF1F5FB8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Foreground" Value="#FF8A5A00" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                    <Setter Property="Foreground" Value="#FFAA2E34" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="170" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="130" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,10"
              IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,8,12,8"
                       VerticalAlignment="Center"
                       Text="Archivordner" />
            <TextBox Grid.Column="1"
                     Margin="0,4,12,4"
                     IsReadOnly="True"
                     Text="{Binding RootDirectory, Mode=OneWay}" />
            <Button Grid.Column="2"
                    Margin="0,2,12,2"
                    Padding="10,6"
                    Command="{Binding SelectRootDirectoryCommand}"
                    Content="Ordner wählen" />
            <Button Grid.Column="3"
                    Margin="0,2,0,2"
                    Padding="10,6"
                    Command="{Binding ScanCommand}"
                    Content="Scannen" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="10,8"
                Background="#FFF8FAFC"
                BorderBrush="#FFD8DEE6"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock TextWrapping="Wrap"
                       Text="{Binding SummaryText, Mode=OneWay}" />
        </Border>

        <GroupBox Grid.Row="2" Header="Archivdateien">
            <DataGrid x:Name="ArchiveItemsGrid"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HorizontalScrollBarVisibility="Auto"
                      IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                      IsReadOnly="False"
                      ColumnWidth="*"
                      KeyboardNavigation.DirectionalNavigation="Contained"
                      PreviewKeyDown="ArchiveItemsGrid_OnPreviewKeyDown"
                      PreviewMouseLeftButtonDown="ArchiveItemsGrid_OnPreviewMouseLeftButtonDown"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      Margin="8"
                      MinHeight="230">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Auswahl"
                                            Width="SizeToHeader"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          IsHitTestVisible="False"
                                          IsChecked="{Binding IsSelected, Mode=OneWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="MKV"
                                        Binding="{Binding FileName}"
                                        Width="2.2*"
                                        MinWidth="260"
                                        IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Status"
                                            Width="Auto"
                                            MinWidth="100"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Margin="2"
                                        Style="{StaticResource StatusBadgeBorderStyle}">
                                    <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                                               Text="{Binding StatusText}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Änderungen / Hinweise"
                                        Binding="{Binding ChangeSummary}"
                                        Width="3*"
                                        MinWidth="360"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Ordner"
                                        Binding="{Binding DirectoryPath}"
                                        Width="1.6*"
                                        MinWidth="180"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="3"
                  Margin="0,10,0,0"
                  Header="Details zur ausgewählten Datei">
            <TextBox Margin="8"
                     Text="{Binding SelectedDetailText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled" />
        </GroupBox>

        <Expander Grid.Row="4"
                  Margin="0,10,0,0"
                  Header="{Binding SelectedItem.ManualCorrectionHeaderText, Mode=OneWay}"
                  IsExpanded="False">
            <Border Padding="8"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFD8DEE6"
                    BorderThickness="1">
                <Grid MaxHeight="310"
                      IsEnabled="{Binding SelectedItem.CanEditManualCorrections, Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,5,8,5"
                           VerticalAlignment="Center"
                           Text="Ziel-Dateiname" />
                    <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="0,2,14,2"
                         Text="{Binding SelectedItem.TargetFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Margin="0,5,8,5"
                           VerticalAlignment="Center"
                           Text="MKV-Titel" />
                    <TextBox Grid.Row="0"
                         Grid.Column="3"
                         Margin="0,2,0,2"
                         Text="{Binding SelectedItem.TargetContainerTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="4"
                           Margin="0,4,0,6"
                           Foreground="#FFAA2E34"
                           TextWrapping="Wrap"
                           Text="{Binding SelectedItem.ManualValidationMessage, Mode=OneWay}" />

                    <DockPanel Grid.Row="2"
                           Grid.ColumnSpan="4"
                           Margin="0,0,0,6">
                    <CheckBox DockPanel.Dock="Right"
                              Margin="12,0,0,0"
                              VerticalAlignment="Center"
                              Content="Alle Track-Werte anzeigen"
                              IsChecked="{Binding SelectedItem.ShowAllHeaderCorrections, Mode=TwoWay}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#FF5F6B76"
                               TextWrapping="Wrap"
                               Text="{Binding SelectedItem.HeaderCorrectionModeText, Mode=OneWay}" />
                </DockPanel>

                    <DataGrid Grid.Row="3"
                          Grid.ColumnSpan="4"
                          ItemsSource="{Binding SelectedItem.VisibleHeaderCorrections, Mode=OneWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeColumns="True"
                          HeadersVisibility="Column"
                          IsReadOnly="False"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          MinHeight="90"
                          MaxHeight="190">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Spur"
                                            Binding="{Binding DisplayLabel}"
                                            Width="2*"
                                            MinWidth="180"
                                            IsReadOnly="True" />
                        <DataGridTextColumn Header="Wert"
                                            Binding="{Binding DisplayName}"
                                            Width="1.1*"
                                            MinWidth="115"
                                            IsReadOnly="True" />
                        <DataGridTextColumn Header="Ist"
                                            Binding="{Binding CurrentDisplayValue}"
                                            Width="1.1*"
                                            MinWidth="115"
                                            IsReadOnly="True" />
                        <DataGridTemplateColumn Header="Soll"
                                                Width="1.4*"
                                                MinWidth="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBox Text="{Binding TargetValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding IsTextValue, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ComboBox ItemsSource="{Binding AvailableFlagValues}"
                                                  SelectedItem="{Binding TargetValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Visibility="{Binding IsFlag, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Expander>

        <StackPanel Grid.Row="5"
                    Margin="0,10,0,10"
                    Orientation="Horizontal"
                    IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding SelectAllWritableCommand}"
                    Content="Alle Änderbaren wählen" />
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding DeselectAllCommand}"
                    Content="Auswahl leeren" />
            <Button Margin="0,0,8,0"
                    Padding="10,6"
                    Command="{Binding OpenSelectedFileCommand}"
                    Content="Datei öffnen" />
            <Button Padding="10,6"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding ApplySelectedCommand}"
                    Content="Ausgewählte Änderungen anwenden" />
        </StackPanel>

        <Expander Grid.Row="6"
                  Header="Protokoll"
                  IsExpanded="False"
                  Expanded="LogExpander_OnExpanded">
            <TextBox x:Name="LogTextBox"
                     Margin="8"
                     Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     TextChanged="LogTextBox_OnTextChanged" />
        </Expander>

        <Grid Grid.Row="7" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding StatusText, Mode=OneWay}" />
            <ProgressBar Grid.Column="1"
                         Height="18"
                         Margin="12,0,0,0"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressValue, Mode=OneWay}">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInteractive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </Grid>
    </Grid>
</UserControl>
