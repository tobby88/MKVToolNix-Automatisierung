<UserControl x:Class="MkvToolnixAutomatisierung.Views.BatchMuxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="190" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Quellordner" />
            <TextBox Grid.Row="0"
                     Grid.Column="1"
                     Margin="0,4,12,4"
                     IsReadOnly="True"
                     ToolTip="Quellordner mit den heruntergeladenen Episoden ausw&#228;hlen. Der Scan startet danach direkt."
                     Text="{Binding SourceDirectory, Mode=OneWay}" />
            <Button Grid.Row="0" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectSourceDirectoryCommand}" Content="Ordner w&#228;hlen" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Serienbibliothek" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Margin="0,4,12,4"
                     IsReadOnly="True"
                     ToolTip="Oberordner der Serienbibliothek auf dem Server."
                     Text="{Binding OutputDirectory, Mode=OneWay}" />
            <Button Grid.Row="1" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectOutputDirectoryCommand}" Content="Bibliothek &#228;ndern" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1.45*" />
                <RowDefinition Height="6" />
                <RowDefinition Height="0.9*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6" LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Filter" />
                    <ComboBox Width="150"
                              Margin="0,0,16,0"
                              ItemsSource="{Binding FilterModes, Mode=OneWay}"
                              SelectedItem="{Binding SelectedFilterMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Sortierung" />
                    <ComboBox Width="160"
                              ItemsSource="{Binding SortModes, Mode=OneWay}"
                              SelectedItem="{Binding SelectedSortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Width="210"
                        Margin="12,0,0,0"
                        Padding="10,6"
                        Command="{Binding RefreshAllComparisonsCommand}"
                        Content="Alle Vergleiche aktualisieren" />
            </DockPanel>

            <GroupBox Grid.Row="1" Header="Gefundene Episoden" MinHeight="150">
                <DataGrid x:Name="EpisodeItemsGrid"
                          ItemsSource="{Binding EpisodeItemsView}"
                          SelectedItem="{Binding SelectedEpisodeItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          Loaded="EpisodeItemsGrid_OnLoaded"
                          MouseDoubleClick="EpisodeItemsGrid_OnMouseDoubleClick"
                          SizeChanged="EpisodeItemsGrid_OnSizeChanged"
                          MinHeight="130"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Auswahl" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                        <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="0.9*" MinWidth="110" IsReadOnly="True" />
                        <DataGridTextColumn Header="S/E" Binding="{Binding EpisodeCodeDisplayText}" Width="Auto" IsReadOnly="True" />

                        <DataGridTemplateColumn Header="In Bibliothek" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="2" Padding="6,2" CornerRadius="9" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#EEF6E8" />
                                                <Setter Property="BorderBrush" Value="#88B06E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ArchiveStateText}" Value="vorhanden">
                                                        <Setter Property="Background" Value="#E8F3FF" />
                                                        <Setter Property="BorderBrush" Value="#8CB4D8" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding ArchiveStateText}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Pr&#252;fung" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="2" Padding="6,2" CornerRadius="9" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F3F6FA" />
                                                <Setter Property="BorderBrush" Value="#C7D1DC" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReviewHint}" Value="Freigegeben">
                                                        <Setter Property="Background" Value="#EEF6E8" />
                                                        <Setter Property="BorderBrush" Value="#88B06E" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ReviewHint}" Value="Keine n&#246;tig">
                                                        <Setter Property="Background" Value="#EEF6E8" />
                                                        <Setter Property="BorderBrush" Value="#88B06E" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ReviewHint}" Value="Quelle + TVDB pr&#252;fen">
                                                        <Setter Property="Background" Value="#FFF4D6" />
                                                        <Setter Property="BorderBrush" Value="#D8B46A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ReviewHint}" Value="Quelle pr&#252;fen">
                                                        <Setter Property="Background" Value="#FFF4D6" />
                                                        <Setter Property="BorderBrush" Value="#D8B46A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ReviewHint}" Value="TVDB pr&#252;fen">
                                                        <Setter Property="Background" Value="#FFF4D6" />
                                                        <Setter Property="BorderBrush" Value="#D8B46A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding ReviewHint}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Status" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="2" Padding="6,2" CornerRadius="9" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F3F6FA" />
                                                <Setter Property="BorderBrush" Value="#C7D1DC" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusSortKey}" Value="0">
                                                        <Setter Property="Background" Value="#FCE8E8" />
                                                        <Setter Property="BorderBrush" Value="#D28A8A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusSortKey}" Value="1">
                                                        <Setter Property="Background" Value="#FFF4D6" />
                                                        <Setter Property="BorderBrush" Value="#D8B46A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusSortKey}" Value="2">
                                                        <Setter Property="Background" Value="#FFF4D6" />
                                                        <Setter Property="BorderBrush" Value="#D8B46A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusSortKey}" Value="3">
                                                        <Setter Property="Background" Value="#E8F3FF" />
                                                        <Setter Property="BorderBrush" Value="#8CB4D8" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusSortKey}" Value="4">
                                                        <Setter Property="Background" Value="#EEF6E8" />
                                                        <Setter Property="BorderBrush" Value="#88B06E" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusSortKey}" Value="5">
                                                        <Setter Property="Background" Value="#EEF6E8" />
                                                        <Setter Property="BorderBrush" Value="#88B06E" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusSortKey}" Value="6">
                                                        <Setter Property="Background" Value="#EEF6E8" />
                                                        <Setter Property="BorderBrush" Value="#88B06E" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding Status}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Quelle" Binding="{Binding MainVideoFileName}" Width="3.2*" MinWidth="220" IsReadOnly="True" SortMemberPath="MainVideoFileName" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Row="2"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D6D6D6"
                          ShowsPreview="True"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <GroupBox Grid.Row="3"
                      Header="Geplante Verwendung des ausgew&#228;hlten Eintrags"
                      Margin="0,6,0,0"
                      MinHeight="120"
                      MaxHeight="300">
                <Grid Margin="8">
                    <Border Padding="18"
                            Background="#F8F8F8"
                            BorderBrush="#D5D5D5"
                            BorderThickness="1"
                            CornerRadius="6"
                            ToolTip="Einen Batch-Eintrag ausw&#228;hlen. Dann erscheint hier die geplante Verwendung in der Serienbibliothek. Doppelklick startet n&#246;tige Pr&#252;fungen oder &#246;ffnet die Details.">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedEpisodeItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="Noch kein Eintrag ausgew&#228;hlt" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedEpisodeItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding SelectedEpisodeItem.Title, Mode=OneWay}" />
                            <TextBlock Margin="0,2,0,0" Opacity="0.75" Text="{Binding SelectedEpisodeItem.MetadataDisplayText, Mode=OneWay}" />

                            <Border Padding="10" Background="#F6F4EA" BorderBrush="#B8AA72" BorderThickness="1" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2,8,2" FontWeight="SemiBold" Text="Serienbibliothek" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,2,0,2" TextWrapping="Wrap">
                                        <Run Text="{Binding SelectedEpisodeItem.UsageSummary.ArchiveAction, Mode=OneWay}" />
                                        <Run Text=": " />
                                        <Run Text="{Binding SelectedEpisodeItem.UsageSummary.ArchiveDetails, Mode=OneWay}" />
                                    </TextBlock>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,2,8,2" FontWeight="SemiBold" Text="Video" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,2,0,2" TextWrapping="Wrap">
                                        <Run Text="{Binding SelectedEpisodeItem.UsageSummary.MainVideo, Mode=OneWay}" />
                                        <Run Text=" | weitere: " />
                                        <Run Text="{Binding SelectedEpisodeItem.UsageSummary.AdditionalVideos, Mode=OneWay}" />
                                    </TextBlock>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,2,8,2" FontWeight="SemiBold" Text="Audio / AD" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,2,0,2" TextWrapping="Wrap">
                                        <Run Text="{Binding SelectedEpisodeItem.UsageSummary.Audio, Mode=OneWay}" />
                                        <Run Text=" | AD: " />
                                        <Run Text="{Binding SelectedEpisodeItem.UsageSummary.AudioDescription, Mode=OneWay}" />
                                    </TextBlock>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,2,8,2" FontWeight="SemiBold" Text="Untertitel" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,2,0,2" TextWrapping="Wrap" Text="{Binding SelectedEpisodeItem.UsageSummary.Subtitles, Mode=OneWay}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,2,8,2" FontWeight="SemiBold" Text="Anh&#228;nge" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,2,0,2" TextWrapping="Wrap" Text="{Binding SelectedEpisodeItem.UsageSummary.Attachments, Mode=OneWay}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </GroupBox>

            <StackPanel Grid.Row="4" Margin="0,6,0,0">
                <TextBlock Margin="0,0,0,4"
                           Text="{Binding StatusText, Mode=OneWay}" />
                <ProgressBar Height="12"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue, Mode=OneWay}" />
            </StackPanel>

            <Expander x:Name="DetailsExpander"
                      Grid.Row="5"
                      Margin="0,6,0,0"
                      Header="Korrekturen und Details"
                      MaxHeight="240"
                      IsExpanded="False">
                <Border Padding="8" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="300">
                        <StackPanel Margin="8">
                            <GroupBox Margin="0,0,0,10" Header="Metadaten">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Episodentitel" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" Text="{Binding SelectedEpisodeItem.TitleForMux, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="TVDB-Status" />
                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBox Margin="0,4,12,4" IsReadOnly="True" Text="{Binding SelectedEpisodeItem.MetadataDisplayText, Mode=OneWay}" />
                                        <TextBox Margin="0,4,12,4" Height="52" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Text="{Binding SelectedEpisodeItem.MetadataStatusText, Mode=OneWay}" />
                                    </StackPanel>
                                    <Button Grid.Row="1" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding ReviewSelectedMetadataCommand}" Content="TVDB pr&#252;fen" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Margin="0,0,0,10" Header="Quellen">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Gefundene Quellen" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" Height="64" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Text="{Binding SelectedEpisodeItem.RequestedSourcesDisplayText, Mode=OneWay}" />
                                    <Button Grid.Row="0" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenSelectedSourcesCommand}" Content="Quelle pr&#252;fen" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Aktive Hauptquelle" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,12,4" Height="48" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Text="{Binding SelectedEpisodeItem.MainVideoDisplayText, Mode=OneWay}" />
                                    <Button Grid.Row="1" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding RedetectSelectedEpisodeCommand}" Content="Video neu erkennen" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Weitere Videos und AD" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,12,4" Height="72" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Text="{Binding SelectedEpisodeItem.VideoAndAudioDescriptionDisplayText, Mode=OneWay}" />
                                    <Button Grid.Row="2" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding EditSelectedAudioDescriptionCommand}" Content="AD korrigieren" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Untertitel" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,4,12,4" Height="72" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Text="{Binding SelectedEpisodeItem.SubtitleDisplayText, Mode=OneWay}" />
                                    <Button Grid.Row="3" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding EditSelectedSubtitlesCommand}" Content="Untertitel korrigieren" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Ausgabe und Hinweise">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Anh&#228;nge" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Margin="0,4,12,4"
                                             Height="64"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             IsReadOnly="True"
                                             Text="{Binding SelectedEpisodeItem.AttachmentDisplayText, Mode=OneWay}" />
                                    <Button Grid.Row="0"
                                            Grid.Column="2"
                                            Margin="0,2,0,2"
                                            Padding="10,6"
                                            VerticalAlignment="Top"
                                            Command="{Binding EditSelectedAttachmentsCommand}"
                                            Content="Anh&#228;nge korrigieren" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Ausgabe" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Margin="0,4,12,4"
                                             IsReadOnly="True"
                                             Text="{Binding SelectedEpisodeItem.OutputPath, Mode=OneWay}" />
                                    <Button Grid.Row="1"
                                            Grid.Column="2"
                                            Margin="0,2,0,2"
                                            Padding="10,6"
                                            Command="{Binding EditSelectedOutputCommand}"
                                            Content="Ausgabe &#228;ndern" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Hinweise" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Grid.ColumnSpan="2"
                                             Margin="0,4,0,4"
                                             Height="64"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             Text="{Binding SelectedEpisodeItem.NotesDisplayText, Mode=OneWay}" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Expander>

            <Expander Grid.Row="6" Header="Batch-Protokoll" Margin="0,6,0,0" IsExpanded="False">
                <TextBox Margin="8"
                         FontFamily="Consolas"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="140"
                         Text="{Binding LogText, Mode=OneWay}" />
            </Expander>
        </Grid>

        <WrapPanel Grid.Row="2" Margin="0,12,0,0">
            <Button Width="150" Margin="0,0,12,0" Padding="10,6" Command="{Binding ScanDirectoryCommand}" Content="Ordner scannen" />
            <Button Width="130" Margin="0,0,12,0" Padding="10,6" Command="{Binding SelectAllEpisodesCommand}" Content="Alle w&#228;hlen" />
            <Button Width="140" Margin="0,0,12,0" Padding="10,6" Command="{Binding DeselectAllEpisodesCommand}" Content="Alle abw&#228;hlen" />
            <Button Width="180" Margin="0,0,12,0" Padding="10,6" Command="{Binding ReviewPendingSourcesCommand}" Content="Pflichtchecks starten" />
            <Button Width="170" Margin="0,0,12,0" Padding="10,6" Command="{Binding RunBatchCommand}" Content="Batch starten" />
        </WrapPanel>
    </Grid>
</UserControl>
