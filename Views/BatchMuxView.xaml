<UserControl x:Class="MkvToolnixAutomatisierung.Views.BatchMuxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MkvToolnixAutomatisierung.Views">
    <UserControl.Resources>
        <!-- Gemeinsame Darstellungsstile für read-only Oberflächen und Inline-Validierung im Batch. -->
        <Style x:Key="DisplaySurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7F7F7" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style x:Key="DisplaySurfaceTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="DisplaySurfacePathTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
        <!-- Detailflächen dürfen für mehrere Einträge etwas wachsen, ohne den Detailbereich unnötig aufzublähen. -->
        <Style x:Key="CompactListSurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource DisplaySurfaceBorderStyle}">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="MaxHeight" Value="104" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="EpisodeIndexTextBoxStyle" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Text" Value="xx">
                    <Setter Property="Background" Value="#FFF4F4" />
                    <Setter Property="BorderBrush" Value="#C85B5B" />
                    <Setter Property="BorderThickness" Value="1.5" />
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Oberer Bereich: Quellordner und aktuell verwendeter Ausgabeordner. -->
        <Grid Grid.Row="0" Margin="0,0,0,8" IsEnabled="{Binding IsInteractive, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="190" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Quellordner" />
            <TextBox Grid.Row="0"
                     Grid.Column="1"
                     Margin="0,4,12,4"
                     IsReadOnly="True"
                     ToolTip="Quellordner mit den heruntergeladenen Episoden ausw&#228;hlen. Der Scan startet danach direkt."
                     Text="{Binding SourceDirectory, Mode=OneWay}" />
            <Button Grid.Row="0" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectSourceDirectoryCommand}" Content="Ordner w&#228;hlen" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Serienbibliothek" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Margin="0,4,12,4"
                     IsReadOnly="True"
                     ToolTip="Oberordner der Serienbibliothek auf dem Server."
                     Text="{Binding OutputDirectory, Mode=OneWay}" />
            <Button Grid.Row="1" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectOutputDirectoryCommand}" Content="Bibliothek &#228;ndern" />

            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Grid.ColumnSpan="2"
                       Margin="0,2,0,0"
                       Foreground="#7A5A00"
                       TextWrapping="Wrap"
                       Text="{Binding OutputDirectoryHintText, Mode=OneWay}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasOutputDirectoryHint, Mode=OneWay}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Hauptbereich: Liste gefundener Episoden plus Detail-/Reviewfläche. -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1.2*" />
                <RowDefinition Height="6" />
                <RowDefinition Height="1.15*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6" LastChildFill="False" IsEnabled="{Binding IsInteractive, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Filter" />
                    <ComboBox Width="150"
                              Margin="0,0,16,0"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding FilterModes, Mode=OneWay}"
                              SelectedItem="{Binding SelectedFilterMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Sortierung" />
                    <ComboBox Width="160"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding SortModes, Mode=OneWay}"
                              SelectedItem="{Binding SelectedSortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Width="210"
                        Margin="12,0,0,0"
                        Padding="10,6"
                        Command="{Binding RefreshAllComparisonsCommand}"
                        ToolTip="{Binding RefreshAllComparisonsTooltip, Mode=OneWay}"
                        Content="Alle Vergleiche aktualisieren" />
            </DockPanel>

            <GroupBox Grid.Row="1" Header="Gefundene Episoden" MinHeight="150">
                <DataGrid x:Name="EpisodeItemsGrid"
                          ItemsSource="{Binding EpisodeItemsView}"
                          SelectedItem="{Binding SelectedEpisodeItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          MouseDoubleClick="EpisodeItemsGrid_OnMouseDoubleClick"
                          MinHeight="130"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Auswahl" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="SizeToHeader" />
                        <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="1.1*" MinWidth="140" IsReadOnly="True" />
                        <DataGridTextColumn Header="S/E" Binding="{Binding EpisodeCodeDisplayText}" Width="Auto" MinWidth="48" IsReadOnly="True" />

                        <DataGridTemplateColumn Header="In Bibliothek" Width="Auto" MinWidth="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="2" Padding="6,2" CornerRadius="9" BorderThickness="1" ToolTip="{Binding ArchiveStateTooltip, Mode=OneWay}">
                                        <Border.Background>
                                            <Binding Path="ArchiveBadgeBackground" Mode="OneWay" />
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <Binding Path="ArchiveBadgeBorderBrush" Mode="OneWay" />
                                        </Border.BorderBrush>
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding ArchiveStateText}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Pr&#252;fung" Width="Auto" MinWidth="86">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="2" Padding="6,2" CornerRadius="9" BorderThickness="1" ToolTip="{Binding ReviewHintTooltip, Mode=OneWay}">
                                        <Border.Background>
                                            <Binding Path="ReviewBadgeBackground" Mode="OneWay" />
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <Binding Path="ReviewBadgeBorderBrush" Mode="OneWay" />
                                        </Border.BorderBrush>
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding ReviewHint}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Status" Width="Auto" MinWidth="78">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="2" Padding="6,2" CornerRadius="9" BorderThickness="1" ToolTip="{Binding StatusTooltip, Mode=OneWay}">
                                        <Border.Background>
                                            <Binding Path="StatusBadgeBackground" Mode="OneWay" />
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <Binding Path="StatusBadgeBorderBrush" Mode="OneWay" />
                                        </Border.BorderBrush>
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding Status}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Quelle" Binding="{Binding MainVideoFileName}" Width="3*" MinWidth="260" IsReadOnly="True" SortMemberPath="MainVideoFileName" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Row="2"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D6D6D6"
                          ShowsPreview="True"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <GroupBox Grid.Row="3"
                      Header="Geplante Verwendung des ausgew&#228;hlten Eintrags"
                      Margin="0,6,0,0"
                      MinHeight="150"
                      MaxHeight="380">
                <Grid Margin="8">
                    <Border Padding="18"
                            Background="#F8F8F8"
                            BorderBrush="#D5D5D5"
                            BorderThickness="1"
                            CornerRadius="6"
                            ToolTip="Einen Batch-Eintrag ausw&#228;hlen. Dann erscheint hier die geplante Verwendung in der Serienbibliothek. Doppelklick startet n&#246;tige Pr&#252;fungen oder &#246;ffnet die Details.">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedEpisodeItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="Noch kein Eintrag ausgew&#228;hlt" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedEpisodeItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding SelectedEpisodeItem.Title, Mode=OneWay}" />
                            <TextBlock Margin="0,2,0,0" Opacity="0.75" Text="{Binding SelectedEpisodeItem.MetadataDisplayText, Mode=OneWay}" />

                            <Border Padding="8" Background="#F6F4EA" BorderBrush="#B8AA72" BorderThickness="1" CornerRadius="6">
                                <views:EpisodeUsageSummaryView DataContext="{Binding SelectedEpisodeItem.UsageSummary, Mode=OneWay}" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </GroupBox>

            <StackPanel Grid.Row="4" Margin="0,6,0,0">
                <TextBlock Margin="0,0,0,4"
                           Text="{Binding StatusText, Mode=OneWay}" />
                <ProgressBar Height="12"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue, Mode=OneWay}" />
            </StackPanel>

            <Expander x:Name="DetailsExpander"
                      Grid.Row="5"
                      Margin="0,6,0,0"
                      Header="Korrekturen und Details"
                      MaxHeight="240"
                      IsEnabled="{Binding IsInteractive, Mode=OneWay}"
                      IsExpanded="False">
                <Border Padding="8" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="300">
                        <StackPanel Margin="8">
                            <GroupBox Margin="0,0,0,10" Header="Metadaten">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Serienname" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" Text="{Binding SelectedEpisodeItem.SeriesName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Staffel / Folge(n)" />
                                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,4,12,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Staffel" />
                                        <TextBox Grid.Column="1"
                                                 Tag="Staffel fehlt oder ist noch ungültig."
                                                 Style="{StaticResource EpisodeIndexTextBoxStyle}"
                                                 PreviewTextInput="EpisodeIndexTextBox_OnPreviewTextInput"
                                                 DataObject.Pasting="EpisodeIndexTextBox_OnPasting"
                                                 Text="{Binding SelectedEpisodeItem.SeasonNumber, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0" Text="Folge(n)" />
                                        <TextBox Grid.Column="4"
                                                 Tag="Folge fehlt oder ist noch ungültig. Für Doppelfolgen kannst du z. B. 05-06 eingeben; intern wird daraus 05-E06."
                                                 Style="{StaticResource EpisodeIndexTextBoxStyle}"
                                                 PreviewTextInput="EpisodeRangeTextBox_OnPreviewTextInput"
                                                 DataObject.Pasting="EpisodeRangeTextBox_OnPasting"
                                                 Text="{Binding SelectedEpisodeItem.EpisodeNumber, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    </Grid>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Episodentitel" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,12,4" Text="{Binding SelectedEpisodeItem.TitleForMux, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="TVDB-Status" />
                                    <StackPanel Grid.Row="3" Grid.Column="1">
                                        <Border Margin="0,4,12,4" Style="{StaticResource DisplaySurfaceBorderStyle}">
                                            <TextBlock Style="{StaticResource DisplaySurfaceTextStyle}"
                                                       Text="{Binding SelectedEpisodeItem.MetadataDisplayText, Mode=OneWay}" />
                                        </Border>
                                        <Border Margin="0,4,12,4" Style="{StaticResource CompactListSurfaceBorderStyle}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <TextBlock Style="{StaticResource DisplaySurfaceTextStyle}"
                                                           Text="{Binding SelectedEpisodeItem.MetadataStatusText, Mode=OneWay}" />
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                    <Button Grid.Row="3" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding ReviewSelectedMetadataCommand}" ToolTip="{Binding ReviewSelectedMetadataTooltip, Mode=OneWay}" Content="TVDB pr&#252;fen" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Margin="0,0,0,10" Header="Quellen">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Gefundene Quellen" />
                                    <Border Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource CompactListSurfaceBorderStyle}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding SelectedEpisodeItem.RequestedSourcePaths, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Margin="0,0,0,4"
                                                                 Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                                                 Text="{Binding Mode=OneWay}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                    <Button Grid.Row="0" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenSelectedSourcesCommand}" ToolTip="{Binding OpenSelectedSourcesTooltip, Mode=OneWay}" Content="Quelle pr&#252;fen" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Aktive Hauptquelle" />
                                    <Border Grid.Row="1" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource CompactListSurfaceBorderStyle}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBox Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                                     Text="{Binding SelectedEpisodeItem.MainVideoDisplayText, Mode=OneWay}" />
                                        </ScrollViewer>
                                    </Border>
                                    <Button Grid.Row="1" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding RedetectSelectedEpisodeCommand}" ToolTip="{Binding RedetectSelectedEpisodeTooltip, Mode=OneWay}" Content="Video neu erkennen" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Weitere Videos und AD" />
                                    <Border Grid.Row="2" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource CompactListSurfaceBorderStyle}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBox Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                                     Text="{Binding SelectedEpisodeItem.VideoAndAudioDescriptionDisplayText, Mode=OneWay}" />
                                        </ScrollViewer>
                                    </Border>
                                    <Button Grid.Row="2" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding EditSelectedAudioDescriptionCommand}" Content="AD korrigieren" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Untertitel" />
                                    <Border Grid.Row="3" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource CompactListSurfaceBorderStyle}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding SelectedEpisodeItem.SubtitlePaths, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Margin="0,0,0,4"
                                                                 Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                                                 Text="{Binding Mode=OneWay}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                    <Button Grid.Row="3" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding EditSelectedSubtitlesCommand}" Content="Untertitel korrigieren" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Ausgabe und Hinweise">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Anh&#228;nge" />
                                    <Border Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="0,4,12,4"
                                            Style="{StaticResource CompactListSurfaceBorderStyle}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding SelectedEpisodeItem.AttachmentPaths, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Margin="0,0,0,4"
                                                                 Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                                                 Text="{Binding Mode=OneWay}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                    <Button Grid.Row="0"
                                            Grid.Column="2"
                                            Margin="0,2,0,2"
                                            Padding="10,6"
                                            VerticalAlignment="Top"
                                            Command="{Binding EditSelectedAttachmentsCommand}"
                                            Content="Anh&#228;nge korrigieren" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Ausgabe" />
                                    <Border Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="0,4,12,4"
                                            Style="{StaticResource DisplaySurfaceBorderStyle}">
                                        <TextBox Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                                 Text="{Binding SelectedEpisodeItem.OutputPath, Mode=OneWay}" />
                                    </Border>
                                    <Button Grid.Row="1"
                                            Grid.Column="2"
                                            Margin="0,2,0,2"
                                            Padding="10,6"
                                            Command="{Binding EditSelectedOutputCommand}"
                                            Content="Ausgabe &#228;ndern" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Hinweise" />
                                    <Border Grid.Row="2"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="2"
                                            Margin="0,4,0,4"
                                            Style="{StaticResource CompactListSurfaceBorderStyle}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding SelectedEpisodeItem.Notes, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="0,0,0,4"
                                                                   Style="{StaticResource DisplaySurfaceTextStyle}"
                                                                   Text="{Binding Mode=OneWay}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Expander>

            <Expander Grid.Row="6"
                      Header="Batch-Protokoll"
                      Margin="0,6,0,0"
                      IsExpanded="False"
                      ToolTip="{Binding BatchLogInfoText, Mode=OneWay}">
                <StackPanel>
                    <TextBlock Margin="8,8,8,0"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Text="{Binding BatchLogInfoText, Mode=OneWay}" />
                    <TextBox Margin="8"
                             FontFamily="Consolas"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="140"
                             Text="{Binding LogText, Mode=OneWay}" />
                </StackPanel>
            </Expander>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    MinWidth="150"
                    Padding="10,6"
                    Command="{Binding CancelBatchOperationCommand}"
                    ToolTip="{Binding CancelBatchOperationTooltip, Mode=OneWay}"
                    Content="{Binding CancelBatchOperationText, Mode=OneWay}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanCancelBatchOperation, Mode=OneWay}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <WrapPanel Margin="0,0,12,0" IsEnabled="{Binding IsInteractive, Mode=OneWay}">
                <Button Width="150" Margin="0,0,12,0" Padding="10,6" Command="{Binding ScanDirectoryCommand}" ToolTip="{Binding ScanDirectoryTooltip, Mode=OneWay}" Content="Ordner scannen" />
                <Button Width="130" Margin="0,0,12,0" Padding="10,6" Command="{Binding SelectAllEpisodesCommand}" Content="Alle w&#228;hlen" />
                <Button Width="140" Margin="0,0,12,0" Padding="10,6" Command="{Binding DeselectAllEpisodesCommand}" Content="Alle abw&#228;hlen" />
                <Button Width="180" Margin="0,0,12,0" Padding="10,6" Command="{Binding ReviewPendingSourcesCommand}" ToolTip="{Binding ReviewPendingSourcesTooltip, Mode=OneWay}" Content="Pflichtchecks starten" />
                <Button Width="170" Margin="0,0,12,0" Padding="10,6" Command="{Binding RunBatchCommand}" ToolTip="{Binding RunBatchTooltip, Mode=OneWay}" Content="Batch starten" />
            </WrapPanel>
        </DockPanel>
    </Grid>
</UserControl>
