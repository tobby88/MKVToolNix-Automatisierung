<UserControl x:Class="MkvToolnixAutomatisierung.Views.BatchMuxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   FontSize="15"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap">Batch-Verarbeitung<LineBreak />Suche mehrere Episoden in einem Ordner und muxe sie nacheinander mit denselben Regeln wie im Einzelmodus.</TextBlock>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="190" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Quellordner" />
            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" IsReadOnly="True" Text="{Binding SourceDirectory, Mode=OneWay}" />
            <Button Grid.Row="0" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectSourceDirectoryCommand}" Content="Ordner waehlen" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Ausgabeordner" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,12,4" IsReadOnly="True" Text="{Binding OutputDirectory, Mode=OneWay}" />
            <Button Grid.Row="1" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectOutputDirectoryCommand}" Content="Ordner aendern" />

            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0" TextWrapping="Wrap" Text="Der Batch sucht Hauptdateien im Quellordner, ignoriert AD-Dateien als Startpunkte und erstellt fuer jede gefundene Episode einen Plan. Bereits vorhandene Ausgabedateien werden beim Scan zunaechst abgewaehlt." />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Gefundene Episoden">
                <DataGrid ItemsSource="{Binding EpisodeItems}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Auswahl" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                        <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Datei" Binding="{Binding MainVideoFileName}" Width="2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <TextBlock Grid.Row="1" Margin="0,12,0,6" Text="{Binding StatusText, Mode=OneWay}" />
            <ProgressBar Grid.Row="2" Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />

            <GroupBox Grid.Row="3" Header="Batch-Protokoll" Margin="0,12,0,0">
                <TextBox Margin="8"
                         FontFamily="Consolas"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding LogText, Mode=OneWay}" />
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Width="170" Margin="0,0,12,0" Padding="10,6" Command="{Binding ScanDirectoryCommand}" Content="Ordner scannen" />
            <Button Width="170" Padding="10,6" Command="{Binding RunBatchCommand}" Content="Batch starten" />
        </StackPanel>
    </Grid>
</UserControl>
