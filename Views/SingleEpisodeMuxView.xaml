<UserControl x:Class="MkvToolnixAutomatisierung.Views.SingleEpisodeMuxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   FontSize="15"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap">Einzelepisode muxen<LineBreak />Waehle eine Episoden-.mp4 oder AD-.mp4 aus. Passende Begleitdateien werden automatisch gesucht. TVDB wird danach direkt abgefragt; nur unsichere Treffer muessen noch bestaetigt werden.</TextBlock>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="190" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Hauptvideo (.mp4)" />
            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" IsReadOnly="True" Text="{Binding MainVideoPath, Mode=OneWay}" />
            <Button Grid.Row="0" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectMainVideoCommand}" Content="Hauptvideo waehlen" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="AD-Datei (.mp4)" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,12,4" IsReadOnly="True" Text="{Binding AudioDescriptionPath, Mode=OneWay}" />
            <Button Grid.Row="1" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectAudioDescriptionCommand}" Content="{Binding AudioDescriptionButtonText, Mode=OneWay}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Untertitel" />
            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,12,4" Height="72" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Text="{Binding SubtitleDisplayText, Mode=OneWay}" />
            <Button Grid.Row="2" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectSubtitlesCommand}" Content="Untertitel korrigieren" />

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Text-Anhaenge (.txt)" />
            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,4,12,4" Height="72" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Text="{Binding AttachmentDisplayText, Mode=OneWay}" />
            <Button Grid.Row="3" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectAttachmentCommand}" Content="Anhaenge korrigieren" />

            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Serienname" />
            <TextBox Grid.Row="4" Grid.Column="1" Margin="0,4,12,4" Text="{Binding SeriesName, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Row="4" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenTvdbLookupCommand}" Content="{Binding MetadataActionButtonText, Mode=OneWay}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Staffel / Folge" />
            <Grid Grid.Row="5" Grid.Column="1" Margin="0,4,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Staffel" />
                <TextBox Grid.Column="1" Text="{Binding SeasonNumber, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0" Text="Folge" />
                <TextBox Grid.Column="4" Text="{Binding EpisodeNumber, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
            <Button Grid.Row="5" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding RescanCommand}" Content="Auto-Erkennung neu" />

            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Dateititel" />
            <TextBox Grid.Row="6" Grid.Column="1" Margin="0,4,12,4" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Ausgabedatei (.mkv)" />
            <TextBox Grid.Row="7" Grid.Column="1" Margin="0,4,12,4" IsReadOnly="True" Text="{Binding OutputPath, Mode=OneWay}" />
            <Button Grid.Row="7" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding SelectOutputCommand}" Content="Ausgabe aendern" />

            <Border Grid.Row="8"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,12"
                    Padding="10"
                    Background="#EEF6E8"
                    BorderBrush="#88B06E"
                    BorderThickness="1"
                    CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasOutputTargetStatus}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding OutputTargetStatusText, Mode=OneWay}" />
            </Border>

            <TextBlock Grid.Row="9"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       Margin="0,8,0,8"
                       TextWrapping="Wrap"
                       Text="Die Videoauswahl startet im MediathekView-Downloadordner. Korrektur-Dialoge starten im Ordner der aktuell verwendeten Hauptquelle. TVDB wird zuerst frisch abgefragt; gespeicherte Zuordnungen helfen nur noch als schwacher Hinweis oder Fallback." />

            <Border Grid.Row="10"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,12"
                    Padding="10"
                    Background="#E8F3FF"
                    BorderBrush="#79A8D8"
                    BorderThickness="1"
                    CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasMetadataStatus}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding MetadataStatusText, Mode=OneWay}" />
                    <Button DockPanel.Dock="Right"
                            Margin="12,0,0,0"
                            Padding="10,6"
                            Command="{Binding OpenTvdbLookupCommand}"
                            Content="{Binding MetadataActionButtonText, Mode=OneWay}" />
                </DockPanel>
            </Border>

            <Border Grid.Row="11"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,12"
                    Padding="10"
                    Background="#FFF4D6"
                    BorderBrush="#D8B46A"
                    BorderThickness="1"
                    CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RequiresManualCheck}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding ManualCheckText, Mode=OneWay}" />
                    <Button DockPanel.Dock="Right"
                            Margin="12,0,0,0"
                            Padding="10,6"
                            Command="{Binding TestSelectedSourcesCommand}"
                            Content="{Binding ManualCheckButtonText, Mode=OneWay}" />
                </DockPanel>
            </Border>

            <Border Grid.Row="12"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,12"
                    Padding="10"
                    Background="#F6F4EA"
                    BorderBrush="#B8AA72"
                    BorderThickness="1"
                    CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasPlanSummary}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Margin="0,0,0,6"
                               Text="Wird voraussichtlich verwendet" />
                    <TextBox AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="72"
                             MaxHeight="110"
                             Text="{Binding PlanSummaryText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <GroupBox Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="3" Header="Vorschau und mkvmerge-Ausgabe" MinHeight="220">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,6" Text="{Binding StatusText, Mode=OneWay}" />
                    <ProgressBar Grid.Row="1" Margin="0,0,0,8" Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                    <TextBox Grid.Row="2"
                             FontFamily="Consolas"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             IsReadOnly="True"
                             MinHeight="180"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding PreviewText, Mode=OneWay}" />
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Width="170" Margin="0,0,12,0" Padding="10,6" Command="{Binding CreatePreviewCommand}" Content="Vorschau erzeugen" />
            <Button Width="170" Padding="10,6" Command="{Binding ExecuteMuxCommand}" Content="Muxen" />
        </StackPanel>
    </Grid>
</UserControl>
