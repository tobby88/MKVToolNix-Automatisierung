<UserControl x:Class="MkvToolnixAutomatisierung.Views.SingleEpisodeMuxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MkvToolnixAutomatisierung.Views">
    <UserControl.Resources>
        <!-- Gemeinsame Darstellungsstile für read-only Oberflächen im Einzelmodus. -->
        <Style x:Key="DisplaySurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7F7F7" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style x:Key="DisplaySurfaceTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="DisplaySurfacePathTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
        <!-- Mehrzeilige Dateilisten dürfen etwas wachsen, bleiben aber bewusst kompakt. -->
        <Style x:Key="CompactListSurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource DisplaySurfaceBorderStyle}">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MaxHeight" Value="92" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="EpisodeIndexTextBoxStyle" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Text" Value="xx">
                    <Setter Property="Background" Value="#FFF4F4" />
                    <Setter Property="BorderBrush" Value="#C85B5B" />
                    <Setter Property="BorderThickness" Value="1.5" />
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF1F5FB8" />
            <Setter Property="BorderBrush" Value="#FF174A90" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF174A90" />
                                <Setter Property="BorderBrush" Value="#FF123A72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF123A72" />
                                <Setter Property="BorderBrush" Value="#FF0D2C57" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF5F6B76" />
                                <Setter Property="Background" Value="#FFE5E7EB" />
                                <Setter Property="BorderBrush" Value="#FFD0D7DE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <DockPanel LastChildFill="True">
        <!-- Untere Aktionsleiste bleibt sichtbar; die inhaltliche Arbeitsflaeche darueber darf komplett scrollen. -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Width="170" Margin="0,0,12,0" Padding="10,6" Command="{Binding CreatePreviewCommand}" ToolTip="{Binding CreatePreviewButtonTooltip, Mode=OneWay}" Content="Vorschau erzeugen" />
            <Button Width="170" Margin="0,0,12,0" Padding="10,6" Command="{Binding CancelCurrentOperationCommand}" ToolTip="{Binding CancelCurrentOperationTooltip, Mode=OneWay}" Content="Abbrechen" />
            <Button Width="170" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding ExecuteMuxCommand}" ToolTip="{Binding ExecuteMuxButtonTooltip, Mode=OneWay}" Content="Muxen" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
        <!-- Oberer Bereich: Quellauswahl, automatische Erkennung und Review-Status. -->
        <StackPanel Margin="0,0,0,12">
            <GroupBox Header="Quelle"
                       Margin="0,0,0,12"
                       ToolTip="Hauptvideo oder subtitle-only-Einstieg w&#228;hlen. Passende AD-Dateien, Untertitel und Anh&#228;nge werden danach automatisch erkannt.">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="190" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Hauptvideo / Untertitel" />
                    <Border Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource DisplaySurfaceBorderStyle}">
                        <TextBox Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                 Text="{Binding MainVideoPath, Mode=OneWay}" />
                    </Border>
                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                        <Button Width="112" Margin="0,2,6,2" Padding="10,6" Command="{Binding SelectMainVideoCommand}" Content="Quelle wählen" />
                        <Button Width="72" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenMainVideoCommand}" Content="Öffnen" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,6,0,8"
                            Padding="8"
                            Background="#F6F4EA"
                            BorderBrush="#B8AA72"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSingleEpisodeStatusBand}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <WrapPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                <Border Margin="0,0,8,6"
                                        Padding="8,3"
                                        CornerRadius="10"
                                        Background="{Binding ExecutionStatusBadgeBackground, Mode=OneWay}"
                                        BorderBrush="{Binding ExecutionStatusBadgeBorderBrush, Mode=OneWay}"
                                        ToolTip="{Binding ExecutionStatusTooltip, Mode=OneWay}"
                                        BorderThickness="1">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding ExecutionStatusBadgeText, Mode=OneWay}" />
                                </Border>

                                <Border Margin="0,0,8,6"
                                        Padding="8,3"
                                        CornerRadius="10"
                                        Background="{Binding OutputTargetBadgeBackground, Mode=OneWay}"
                                        BorderBrush="{Binding OutputTargetBadgeBorderBrush, Mode=OneWay}"
                                        ToolTip="{Binding OutputTargetBadgeTooltip, Mode=OneWay}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPlanSummary}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding OutputTargetBadgeText, Mode=OneWay}" />
                                </Border>

                                <Border Margin="0,0,8,6"
                                        Padding="8,3"
                                        CornerRadius="10"
                                        Background="{Binding ManualCheckBadgeBackground, Mode=OneWay}"
                                        BorderBrush="{Binding ManualCheckBadgeBorderBrush, Mode=OneWay}"
                                        ToolTip="{Binding ManualCheckBadgeTooltip, Mode=OneWay}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPlanSummary}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding ManualCheckBadgeText, Mode=OneWay}" />
                                </Border>

                                <Border Margin="0,0,0,6"
                                        Padding="8,3"
                                        CornerRadius="10"
                                        Background="{Binding MetadataBadgeBackground, Mode=OneWay}"
                                        BorderBrush="{Binding MetadataBadgeBorderBrush, Mode=OneWay}"
                                        ToolTip="{Binding MetadataBadgeTooltip, Mode=OneWay}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPlanSummary}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding MetadataBadgeText, Mode=OneWay}" />
                                </Border>
                            </WrapPanel>
                            <views:EpisodeUsageSummaryView DataContext="{Binding UsageSummary, Mode=OneWay}">
                                <views:EpisodeUsageSummaryView.Style>
                                    <Style TargetType="{x:Type views:EpisodeUsageSummaryView}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPlanSummary}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </views:EpisodeUsageSummaryView.Style>
                            </views:EpisodeUsageSummaryView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,8"
                            Padding="10"
                            Background="#FFF4D6"
                            BorderBrush="#D8B46A"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPendingPlanReview, Mode=OneWay}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold"
                                           Text="Wichtiger Hinweis vor dem Muxen" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding PrimaryActionablePlanNote, Mode=OneWay}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    MinWidth="132"
                                    Margin="12,0,0,0"
                                    Padding="10,6"
                                    VerticalAlignment="Center"
                                    Command="{Binding ApprovePlanReviewCommand}"
                                    Content="Hinweis geprüft" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,8"
                            Padding="10"
                            Background="#FCE8E8"
                            BorderBrush="#D28A8A"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPlanRefreshProblem}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock TextWrapping="Wrap"
                                   Text="{Binding PlanRefreshProblemText, Mode=OneWay}" />
                    </Border>

                    <Border Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,4"
                            Padding="10"
                            Background="#FFF4D6"
                            BorderBrush="#D8B46A"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RequiresManualCheck}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Text="{Binding ManualCheckText, Mode=OneWay}" />
                            <Button DockPanel.Dock="Right"
                                    Margin="12,0,0,0"
                                    Padding="10,6"
                                    Command="{Binding TestSelectedSourcesCommand}"
                                    ToolTip="{Binding ManualCheckButtonTooltip, Mode=OneWay}"
                                    Content="{Binding ManualCheckButtonText, Mode=OneWay}" />
                        </DockPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Header="Metadaten">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="190" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Serienname" />
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" Text="{Binding SeriesName, UpdateSourceTrigger=LostFocus}" />
                    <Button Grid.Row="0" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenTvdbLookupCommand}" ToolTip="{Binding MetadataActionButtonTooltip, Mode=OneWay}" Content="{Binding MetadataActionButtonText, Mode=OneWay}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Staffel / Folge(n)" />
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,4,12,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Staffel" />
                        <TextBox Grid.Column="1"
                                 Tag="Staffel fehlt oder ist noch ungültig."
                                 Style="{StaticResource EpisodeIndexTextBoxStyle}"
                                 PreviewTextInput="EpisodeIndexTextBox_OnPreviewTextInput"
                                 DataObject.Pasting="EpisodeIndexTextBox_OnPasting"
                                 Text="{Binding SeasonNumber, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0" Text="Folge(n)" />
                        <TextBox Grid.Column="4"
                                 Tag="Folge fehlt oder ist noch ungültig. Für Doppelfolgen kannst du z. B. 05-06 eingeben; intern wird daraus 05-E06."
                                 Style="{StaticResource EpisodeIndexTextBoxStyle}"
                                 PreviewTextInput="EpisodeRangeTextBox_OnPreviewTextInput"
                                 DataObject.Pasting="EpisodeRangeTextBox_OnPasting"
                                 Text="{Binding EpisodeNumber, UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                    <Button Grid.Row="1" Grid.Column="2" Margin="0,2,0,2" Padding="10,6" Command="{Binding RescanCommand}" ToolTip="{Binding RescanButtonTooltip, Mode=OneWay}" Content="Auto-Erkennung neu" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Episodentitel" />
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,12,4" Text="{Binding Title, UpdateSourceTrigger=LostFocus}" />

                    <Border Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,4,0,4"
                            Padding="10"
                            Background="#E8F3FF"
                            BorderBrush="#79A8D8"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasMetadataStatus}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Text="{Binding MetadataStatusText, Mode=OneWay}" />
                            <Button DockPanel.Dock="Right"
                                    Margin="12,0,0,0"
                                    Padding="10,6"
                                    Command="{Binding OpenTvdbLookupCommand}"
                                    ToolTip="{Binding MetadataActionButtonTooltip, Mode=OneWay}"
                                    Content="{Binding MetadataActionButtonText, Mode=OneWay}" />
                        </DockPanel>
                    </Border>
                </Grid>
            </GroupBox>
        </StackPanel>

        <Expander
                  Header="Korrekturen und Ausgabe"
                  Margin="0,0,0,12"
                  ToolTip="Nur bei Bedarf &#246;ffnen, um automatische Zuordnungen oder die Ausgabedatei manuell anzupassen."
                  IsExpanded="False">
            <Border Padding="8" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4">
                <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="190" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="AD-Datei (.mp4)" />
                <Border Grid.Row="0" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource DisplaySurfaceBorderStyle}">
                    <TextBox Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                             Text="{Binding AudioDescriptionPath, Mode=OneWay}" />
                </Border>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                    <Button Width="112" Margin="0,2,6,2" Padding="10,6" Command="{Binding SelectAudioDescriptionCommand}" Content="{Binding AudioDescriptionButtonText, Mode=OneWay}" />
                    <Button Width="72" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenAudioDescriptionCommand}" Content="Öffnen" />
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Untertitel" />
                <Border Grid.Row="1" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource CompactListSurfaceBorderStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SubtitlePaths, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBox Margin="0,0,0,4"
                                             Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                             Text="{Binding Mode=OneWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                    <Button Width="112" Margin="0,2,6,2" Padding="10,6" Command="{Binding SelectSubtitlesCommand}" Content="UT korrigieren" />
                    <Button Width="72" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenSubtitlesCommand}" Content="Öffnen" />
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Top" Text="Metadaten-Anhänge (.txt)" />
                <Border Grid.Row="2" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource CompactListSurfaceBorderStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AttachmentPaths, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBox Margin="0,0,0,4"
                                             Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                                             Text="{Binding Mode=OneWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                    <Button Width="112" Margin="0,2,6,2" Padding="10,6" Command="{Binding SelectAttachmentCommand}" Content="Anhänge ändern" />
                    <Button Width="72" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenAttachmentsCommand}" Content="Öffnen" />
                </StackPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Ausgabedatei (.mkv)" />
                <Border Grid.Row="3" Grid.Column="1" Margin="0,4,12,4" Style="{StaticResource DisplaySurfaceBorderStyle}">
                    <TextBox Style="{StaticResource DisplaySurfacePathTextBoxStyle}"
                             Text="{Binding OutputPath, Mode=OneWay}" />
                </Border>
                <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal">
                    <Button Width="112" Margin="0,2,6,2" Padding="10,6" Command="{Binding SelectOutputCommand}" Content="Ausgabe ändern" />
                    <Button Width="72" Margin="0,2,0,2" Padding="10,6" Command="{Binding OpenOutputCommand}" Content="Öffnen" />
                </StackPanel>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Video-Sprache" />
                <ComboBox Grid.Row="4"
                          Grid.Column="1"
                          Margin="0,4,12,4"
                          Width="180"
                          HorizontalAlignment="Left"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          ItemsSource="{Binding LanguageOverrideOptions, Mode=OneWay}"
                          SelectedValue="{Binding VideoLanguageOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Überschreibt die automatisch erkannte Sprache aller geplanten Videospuren." />

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Audio-Sprache" />
                <ComboBox Grid.Row="5"
                          Grid.Column="1"
                          Margin="0,4,12,4"
                          Width="180"
                          HorizontalAlignment="Left"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          ItemsSource="{Binding LanguageOverrideOptions, Mode=OneWay}"
                          SelectedValue="{Binding AudioLanguageOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Überschreibt die automatisch erkannte Sprache aller normalen Tonspuren." />

                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Originalsprache" />
                <ComboBox Grid.Row="6"
                          Grid.Column="1"
                          Margin="0,4,12,4"
                          Width="180"
                          HorizontalAlignment="Left"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          ItemsSource="{Binding LanguageOverrideOptions, Mode=OneWay}"
                          SelectedValue="{Binding OriginalLanguageOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Steuert die original-Flags. Automatisch nutzt die Originalsprache aus TVDB." />

                <Border Grid.Row="7"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,4,0,4"
                        Padding="10"
                        Background="#EEF6E8"
                        BorderBrush="#88B06E"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasOutputTargetStatus}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock TextWrapping="Wrap" Text="{Binding OutputTargetStatusText, Mode=OneWay}" />
                </Border>
                </Grid>
            </Border>
        </Expander>

        <GroupBox Header="Status und Details">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Margin="0,0,0,6" TextWrapping="Wrap" Text="{Binding StatusText, Mode=OneWay}" />
                <ProgressBar Grid.Row="1" Margin="0,0,0,8" Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />

                <Expander Grid.Row="2"
                          Header="Details und mkvmerge-Ausgabe"
                          IsExpanded="False"
                          Expanded="PreviewExpander_OnExpanded">
                    <TextBox x:Name="PreviewTextBox"
                             Margin="0,8,0,0"
                             FontFamily="Consolas"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             IsReadOnly="True"
                             MinHeight="220"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="PreviewTextBox_OnTextChanged"
                             Text="{Binding PreviewText, Mode=OneWay}" />
                </Expander>
            </Grid>
        </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
