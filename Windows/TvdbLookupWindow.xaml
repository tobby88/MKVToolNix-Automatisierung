<Window x:Class="MkvToolnixAutomatisierung.Windows.TvdbLookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TVDB-Zuordnung"
        Width="980"
        Height="760"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <!-- Oben: Zugangsdaten und Suchparameter. Mitte: Serien-/Episodenauswahl. Unten: Übernahme oder Abbruch. -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12" IsEnabled="{Binding IsInteractive}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="TVDB API-Key" />
            <TextBox Grid.Row="0"
                     Grid.Column="1"
                     Margin="0,4,12,4"
                     Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="TVDB-API-Schl&#252;ssel f&#252;r die automatische Serien- und Episodensuche." />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Margin="0,2,0,2"
                    Padding="10,6"
                    IsEnabled="{Binding IsInteractive}"
                    Click="SaveSettingsButton_Click"
                    Content="Speichern" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="TVDB PIN (optional)" />
            <PasswordBox x:Name="PinPasswordBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,4,12,4"
                         PasswordChanged="PinPasswordBox_PasswordChanged"
                         ToolTip="Nur eintragen, wenn TVDB zus&#228;tzlich eine PIN verlangt." />
        </Grid>

        <Grid Grid.Row="1" IsEnabled="{Binding IsInteractive}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,12"
                    Padding="10"
                    Background="#F3F6FA"
                    BorderBrush="#C7D1DC"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,8"
                               Text="{Binding GuessSummaryText}"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding ComparisonSummaryText}"
                               TextWrapping="Wrap"
                               Foreground="#334A62" />
                </Grid>
            </Border>

            <GroupBox Grid.Row="1" Grid.Column="0" Header="Serie">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Row="0"
                             Grid.Column="0"
                             Margin="0,0,12,8"
                             Text="{Binding SeriesSearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Seriennamen suchen oder anpassen. Beim &#214;ffnen wird bereits automatisch gesucht." />
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Padding="10,6"
                            Click="SearchSeriesButton_Click"
                            Content="Neu suchen" />

                    <ListBox x:Name="SeriesResultsListBox"
                             Grid.Row="1"
                             Grid.Column="0"
                             Grid.ColumnSpan="2"
                             ItemsSource="{Binding SeriesResults}"
                             SelectedItem="{Binding SelectedSeriesItem, Mode=TwoWay}"
                             SelectionChanged="SeriesResultsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1" Grid.Column="2" Header="Episode">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Row="0"
                             Grid.Column="0"
                             Margin="0,0,0,8"
                             Text="{Binding EpisodeSearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Episodenliste der gew&#228;hlten Serie filtern, z. B. nach Titel oder S01E02." />

                    <ListBox Grid.Row="1"
                             Grid.Column="0"
                             ItemsSource="{Binding EpisodeResults}"
                             SelectedItem="{Binding SelectedEpisodeItem, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Text="{Binding StatusText}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="190"
                        Margin="0,0,12,0"
                        Padding="10,6"
                        IsEnabled="{Binding IsInteractive}"
                        Click="KeepLocalButton_Click"
                        Content="Lokale Erkennung behalten" />
                <Button Width="120" Margin="0,0,12,0" Padding="10,6" Click="CancelButton_Click" Content="Abbrechen" />
                <Button Width="140"
                        Padding="10,6"
                        IsEnabled="{Binding CanApply}"
                        Click="ApplyButton_Click"
                        Content="Übernehmen" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
