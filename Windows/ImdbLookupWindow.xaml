<Window x:Class="MkvToolnixAutomatisierung.Windows.ImdbLookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMDb-Zuordnung"
        Width="820"
        Height="780"
        MinWidth="720"
        MinHeight="680"
        Activated="Window_OnActivated"
        Loaded="Window_OnLoaded"
        Closed="Window_OnClosed"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="10"
                Background="#F3F6FA"
                BorderBrush="#C7D1DC"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Margin="0,0,0,8" Text="{Binding GuessSummaryText}" TextWrapping="Wrap" />
                <TextBlock Foreground="#334A62" Text="{Binding ComparisonSummaryText}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="1" Header="Lokalen IMDb-Index durchsuchen">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ListView Grid.Row="0"
                          MaxHeight="150"
                          ItemsSource="{Binding LocalCandidates}"
                          SelectedItem="{Binding SelectedLocalCandidate, Mode=TwoWay}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="105" Header="IMDb-ID" DisplayMemberBinding="{Binding ImdbId}" />
                            <GridViewColumn Width="150" Header="Serie" DisplayMemberBinding="{Binding SeriesTitle}" />
                            <GridViewColumn Width="270" Header="Episode" DisplayMemberBinding="{Binding EpisodeTitle}" />
                            <GridViewColumn Width="85" Header="IMDb S/E" DisplayMemberBinding="{Binding EpisodeCode}" />
                            <GridViewColumn Width="95" Header="Treffer" DisplayMemberBinding="{Binding MatchQualityText}" />
                        </GridView>
                    </ListView.View>
                </ListView>
                <DockPanel Grid.Row="1" Margin="0,8,0,0" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right" Margin="12,0,0,0" Orientation="Horizontal">
                        <Button x:Name="RefreshLocalCandidatesButton"
                                Padding="12,6"
                                Click="RefreshLocalCandidatesButton_Click"
                                Content="Lokal neu suchen"
                                IsEnabled="{Binding CanRefreshLocalCandidates}"
                                ToolTip="Durchsucht den Offlineindex erneut mit dem unten eingetragenen Seriennamen und Episodentitel." />
                        <Button Margin="8,0,0,0"
                                Padding="12,6"
                                Click="ApplyLocalCandidateButton_Click"
                                Content="Kandidat übernehmen"
                                IsEnabled="{Binding CanApplyLocalCandidate}" />
                    </StackPanel>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#4B5563"
                               Text="{Binding LocalDatasetStatusText}"
                               TextWrapping="Wrap" />
                </DockPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Margin="0,12,0,0" Header="Suchangaben und IMDb im Browser suchen">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Serie" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4" Text="{Binding SeriesSearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Episodentitel" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4" Text="{Binding EpisodeSearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="Freier Suchtext" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,0,8" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding SearchOptions}"
                             SelectedItem="{Binding SelectedSearchOption, Mode=TwoWay}"
                             MouseDoubleClick="SearchOptionsListBox_OnMouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayText}" />
                                    <TextBlock Margin="0,2,0,0" Foreground="#4B5563" Text="{Binding Description}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="1"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Padding="14,7"
                            Click="OpenSearchButton_Click"
                            Content="Ausgewählte Suche öffnen"
                            IsEnabled="{Binding CanOpenSelectedSearch}" />
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Margin="0,12,0,0" Header="IMDb-ID übernehmen">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,8,12,8" VerticalAlignment="Center" Text="IMDb-ID / URL" />
                <TextBox Grid.Column="1"
                         Margin="0,4,12,4"
                         Text="{Binding ImdbInput, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Akzeptiert eine IMDb-ID wie tt1234567 oder eine vollständige IMDb-Titel-URL." />
                <Button Grid.Column="2"
                        Margin="0,4"
                        Padding="10,6"
                        Click="ImportClipboardButton_Click"
                        Content="Zwischenablage übernehmen" />
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="4" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Text="{Binding StatusText}" TextWrapping="Wrap" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="150" Margin="0,0,12,0" Padding="10,6" Click="NoImdbButton_Click" Content="Keine IMDb-ID" />
                <Button Width="120" Margin="0,0,12,0" Padding="10,6" Click="CancelButton_Click" Content="Abbrechen" />
                <Button Width="140" Padding="10,6" IsEnabled="{Binding CanApply}" Click="ApplyButton_Click" Content="Übernehmen" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
