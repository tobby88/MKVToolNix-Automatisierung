<Window x:Class="MkvToolnixAutomatisierung.Windows.ImdbLookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMDb-Zuordnung"
        Width="840"
        Height="620"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="10"
                Background="#F3F6FA"
                BorderBrush="#C7D1DC"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Text="{Binding GuessSummaryText}"
                       TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="IMDb-Suche">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Row="0"
                             Grid.Column="0"
                             Margin="0,0,12,8"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Suchtext für die browsergestützte IMDb-Suche. Der Dialog erzeugt daraus passende Suchlinks." />
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Padding="10,6"
                            Click="OpenSearchButton_Click"
                            Content="Im Browser öffnen"
                            IsEnabled="{Binding CanOpenSelectedSearch}" />

                    <ListBox Grid.Row="1"
                             Grid.Column="0"
                             Grid.ColumnSpan="2"
                             ItemsSource="{Binding SearchOptions}"
                             SelectedItem="{Binding SelectedSearchOption, Mode=TwoWay}"
                             MouseDoubleClick="SearchOptionsListBox_OnMouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding DisplayText}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="#4B5563"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2"
                      Margin="0,12,0,0"
                      Header="IMDb-ID übernehmen">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,8,12,8"
                               VerticalAlignment="Center"
                               Text="IMDb-ID / URL" />
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             Text="{Binding ImdbInput, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Akzeptiert sowohl eine IMDb-ID wie tt1234567 als auch eine komplette IMDb-URL." />

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="Nach der Browser-Suche die gewünschte IMDb-ID oder die komplette IMDb-URL hier einfügen und übernehmen."
                               TextWrapping="Wrap" />
                </Grid>
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding StatusText}"
                       TextWrapping="Wrap" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="120"
                        Margin="0,0,12,0"
                        Padding="10,6"
                        Click="CancelButton_Click"
                        Content="Abbrechen" />
                <Button Width="140"
                        Padding="10,6"
                        IsEnabled="{Binding CanApply}"
                        Click="ApplyButton_Click"
                        Content="Übernehmen" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
